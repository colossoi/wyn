{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "wyn-playground",
	"compatibility_date": "2025-04-15",
	"main": "./workers/app.ts",
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist/client"
	},
	"observability": {
		"enabled": true
	},
	// --- Auth + save/load bindings ---
	//
	// Run once per environment, then paste the resulting IDs here:
	//
	//   wrangler kv namespace create SESSIONS
	//   wrangler d1 create wyn
	//   wrangler secret put GITHUB_CLIENT_SECRET
	//   wrangler secret put SESSION_COOKIE_SECRET
	//   wrangler d1 execute wyn --remote --file=./migrations/0001_init.sql
	//
	// Register two GitHub OAuth Apps at github.com/settings/developers (dev
	// + prod) and put the client IDs below. The client secret and the
	// session HMAC key are injected via `wrangler secret put`.
	"vars": {
		"GITHUB_CLIENT_ID": "Ov23lifGwLSg5YE1Arzc",
		// Comma-separated GitHub logins with admin privileges (managing
		// featured shaders, etc.). Case-insensitive.
		"ADMIN_LOGINS": "colossoi",
		// From-address for transactional mail (login codes). Must be on a
		// domain that's set up under Cloudflare Email Routing for this
		// account, with DKIM/SPF records published — otherwise the
		// `send_email` binding will refuse the message.
		"LOGIN_FROM_EMAIL": "no-reply@finue.com",
		"LOGIN_FROM_NAME": "Wyn Playground"
	},
	// Outbound mail via Cloudflare Email Workers. Omitting
	// `destination_address` puts the binding in unrestricted mode — the
	// recipient can be any address. Requires DKIM on the sender domain
	// (configured in the Email Routing dashboard for the FROM domain).
	"send_email": [
		{
			"name": "MAILER"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSIONS",
			"id": "58098028104d40068c27e92702cb795e"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "wyn",
			"database_id": "1d1ae428-8c0e-433d-b73e-063500937e3e"
		}
	],
	// Custom domain. The `finue.com` zone must already be on this
	// Cloudflare account; the deploy auto-creates a CNAME for the
	// subdomain and provisions a TLS cert (~1–2 min the first time).
	"routes": [
		{
			"pattern": "wyn.finue.com",
			"custom_domain": true
		}
	]
}
