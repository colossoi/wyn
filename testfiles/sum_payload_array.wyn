-- Sum-type lowering with a mixed array / scalar / nullary variant.
-- The flat-no-sharing layout forces every #small or #empty value to
-- carry a blank-filled [4]i32 slot. This testfile exercises that
-- blank-fill path: the #big variant is reachable from `match` but not
-- constructed at the call site (a separate type-checker limitation
-- with array-literal-to-sum-payload-array unification, unrelated to
-- the blank generator).

def verts: [3]vec4f32 =
  [@[-1.0f32, -1.0f32, 0.0f32, 1.0f32],
   @[3.0f32, -1.0f32, 0.0f32, 1.0f32],
   @[-1.0f32, 3.0f32, 0.0f32, 1.0f32]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 =
  verts[vertex_id]

def shade(t: #big([4]i32) | #small(i32) | #empty) i32 =
  match t
  case #big(arr) -> arr[0] + arr[3]
  case #small(x) -> x
  case #empty    -> 0

#[fragment]
entry fragment_main(#[builtin(position)] _fc: vec4f32) #[location(0)] vec4f32 =
  let b = shade(#small(7)) in
  let c = shade(#empty) in
  @[f32.i32(b) / 255.0f32, f32.i32(c) / 255.0f32, 0.0f32, 1.0f32]
