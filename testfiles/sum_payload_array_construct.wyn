-- KNOWN-FAILING. Reminder that constructing a sum-typed value whose
-- active variant carries an array payload (e.g. `#big([1,2,3,4])`)
-- currently fails type unification:
--
--   Type mismatch: expected Array[i32, 4, ?addrspace],
--                  got Array[i32, 4, composite]
--
-- The sum-payload array type carries an unresolved
-- `AddressPlaceholder` (`?addrspace`) that the type checker should
-- replace with a type variable before unification — entry-point
-- params get this treatment but sum-variant payloads don't. The
-- blank-fill path itself works (see `sum_payload_array.wyn`); this
-- is a separate type-checker gap on the active-variant construction
-- side. Listed in scripts/validate_testfiles.sh skip set until fixed.

def verts: [3]vec4f32 =
  [@[-1.0f32, -1.0f32, 0.0f32, 1.0f32],
   @[3.0f32, -1.0f32, 0.0f32, 1.0f32],
   @[-1.0f32, 3.0f32, 0.0f32, 1.0f32]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 =
  verts[vertex_id]

def shade(t: #big([4]i32) | #small(i32) | #empty) i32 =
  match t
  case #big(arr) -> arr[0] + arr[3]
  case #small(x) -> x
  case #empty    -> 0

#[fragment]
entry fragment_main(#[builtin(position)] _fc: vec4f32) #[location(0)] vec4f32 =
  let a = shade(#big([1, 2, 3, 4])) in
  let b = shade(#small(7)) in
  let c = shade(#empty) in
  @[f32.i32(a) / 255.0f32, f32.i32(b) / 255.0f32, f32.i32(c) / 255.0f32, 1.0f32]
