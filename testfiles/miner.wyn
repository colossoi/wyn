-- Bitcoin miner: compute double-SHA256 for block headers
--
-- Maps over the nonce space. The header (minus nonce) is provided once,
-- and each thread tries a different nonce value, computing sha256d.

------------------------------------------------------------
-- Linked external function: SHA256 compression
------------------------------------------------------------
#[linked("sha256_compress")]
extern sha256_compress(state: [8]u32, block: [16]u32) [8]u32

------------------------------------------------------------
-- SHA256 Initial Hash Values (first 32 bits of fractional
-- parts of square roots of first 8 primes)
------------------------------------------------------------
def SHA256_IV: [8]u32 = [
    0x6a09e667u32, 0xbb67ae85u32, 0x3c6ef372u32, 0xa54ff53au32,
    0x510e527fu32, 0x9b05688cu32, 0x1f83d9abu32, 0x5be0cd19u32
]

------------------------------------------------------------
-- sha256_32: Hash a 32-byte message (8 u32s)
-- Single compression round with padding
------------------------------------------------------------
def sha256_32(msg: [8]u32) [8]u32 =
    -- Build padded block: 8 words + padding + length (256 bits = 0x100)
    let block: [16]u32 = [
        msg[0], msg[1], msg[2], msg[3],
        msg[4], msg[5], msg[6], msg[7],
        0x80000000u32,  -- padding start
        0u32, 0u32, 0u32, 0u32, 0u32,  -- zeros (indices 9-13)
        0x00000000u32,  -- high 32 bits of length
        0x00000100u32   -- low 32 bits of length (256 bits)
    ] in
    sha256_compress(SHA256_IV, block)

------------------------------------------------------------
-- mine_nonce: Double SHA256 of the header for a specific nonce, given
-- the precomputed nonce-independent midstate (the first compression
-- block of the 80-byte header — see `mine` below).
------------------------------------------------------------
def mine_nonce(midstate: [8]u32, header_base: [19]u32, nonce: u32) [8]u32 =
    -- Second compression block of the 80-byte header: words 16-18 and the
    -- nonce (word 19), then SHA-256 padding (0x80000000, zeros, and the
    -- 64-bit message length = 640 bits = 0x280).
    let block2: [16]u32 = [
        header_base[16], header_base[17], header_base[18], nonce,
        0x80000000u32,  -- padding start (index 4)
        0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32,  -- zeros (indices 5-13)
        0x00000000u32,  -- high 32 bits of length (index 14)
        0x00000280u32   -- low 32 bits of length (index 15)
    ] in
    -- First SHA-256 finishes from the midstate; second SHA-256 hashes that digest.
    sha256_32(sha256_compress(midstate, block2))

-- Compare two 256-bit integers stored least-significant word first
-- (index 0 = LSB, index 7 = MSB), most significant word first so the
-- first differing word decides. Constant indices keep this as register
-- `OpCompositeExtract`s; a dynamic-index loop would spill `hash`/`target`
-- to Function-storage arrays, which inherit the buffer's explicit layout
-- decorations (illegal outside StorageBuffer).
def hash_below_target(hash: [8]u32, target: [8]u32) bool =
    if hash[7] < target[7] then true
    else if hash[7] > target[7] then false
    else if hash[6] < target[6] then true
    else if hash[6] > target[6] then false
    else if hash[5] < target[5] then true
    else if hash[5] > target[5] then false
    else if hash[4] < target[4] then true
    else if hash[4] > target[4] then false
    else if hash[3] < target[3] then true
    else if hash[3] > target[3] then false
    else if hash[2] < target[2] then true
    else if hash[2] > target[2] then false
    else if hash[1] < target[1] then true
    else if hash[1] > target[1] then false
    else if hash[0] < target[0] then true
    else false

def NO_HIT: (u32, [8]u32) =
    (0xFFFFFFFFu32, [0xFFFFFFFFu32, 0xFFFFFFFFu32, 0xFFFFFFFFu32, 0xFFFFFFFFu32,
                     0xFFFFFFFFu32, 0xFFFFFFFFu32, 0xFFFFFFFFu32, 0xFFFFFFFFu32])

def pick_better(a: (u32, [8]u32), b: (u32, [8]u32)) (u32, [8]u32) =
    if a.0 == 0xFFFFFFFFu32 then b else a

------------------------------------------------------------
-- Compute shader entry point
-- Reduces over nonce space: hash + check target on GPU,
-- only propagate hits through the reduce.
------------------------------------------------------------
#[compute]
entry mine(header_base: [19]u32, target: [8]u32, n: u32, nonce_offset: u32) (u32, [8]u32) =
    -- The first compression block is header words 0-15 (the nonce is
    -- word 19, in the second block), so its compression is independent
    -- of the nonce. Compute this midstate once and share it across the
    -- whole nonce map instead of recomputing it per nonce.
    let block1: [16]u32 = header_base[0..16] in
    let midstate = sha256_compress(SHA256_IV, block1) in
    let candidates = map(|nonce: u32|
        let hash = mine_nonce(midstate, header_base, nonce + nonce_offset) in
        if hash_below_target(hash, target) then (nonce + nonce_offset, hash) else NO_HIT,
    0u32..<n) in
    reduce(pick_better, NO_HIT, candidates)
