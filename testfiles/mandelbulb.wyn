-- "Mandelbulb" by evilryu — Wyn port of the Shadertoy shader.
-- Raymarched Mandelbulb fractal (power=8) with sphere-tracing, soft
-- shadows, and an analytic gradient normal. The original GLSL is
-- preserved commented-out below.

------------------------------------------------------------
-- Uniforms
------------------------------------------------------------
#[uniform(set=1, binding=0)] def iResolution: vec2f32
#[uniform(set=1, binding=1)] def iTime: f32

------------------------------------------------------------
-- Rotate (p.x, p.z) by angle a around the y axis.
------------------------------------------------------------
def ry(p: vec3f32, a: f32) vec3f32 =
  let c = f32.cos(a) in
  let s = f32.sin(a) in
  @[c * p.x + s * p.z, p.y, 0.0 - s * p.x + c * p.z]

------------------------------------------------------------
-- Mandelbulb distance estimator (power 8).
--
-- Returns (distance_estimate, orbit_min, 0) — the second component is
-- the closest approach across the 7 iterations, which we fold into the
-- palette coordinate for coloring.
------------------------------------------------------------
def mb(p_in: vec3f32) vec3f32 =
  -- Original swizzles p.xyz = p.xzy, i.e. swap y and z.
  let p = @[p_in.x, p_in.z, p_in.y] in
  let power = 8.0 in
  let iters = 7 in
  -- Loop state: (i, z, dr, orbit_min)
  let (_, z_final, dr_final, orbit_min) =
    loop (i, z, dr, t0) = (0, p, 1.0, 1.0) while i < iters do
      let r = magnitude(z) in
      if r > 2.0 then (i + 1, z, dr, t0)
      else
        let theta = atan(z.y / z.x) in
        let phi   = asin(z.z / r) in
        let dr2   = pow(r, power - 1.0) * dr * power + 1.0 in
        let rn    = pow(r, power) in
        let th    = theta * power in
        let ph    = phi * power in
        let zn = @[rn * f32.cos(th) * f32.cos(ph),
                   rn * f32.sin(th) * f32.cos(ph),
                   rn * f32.sin(ph)] + p in
        (i + 1, zn, dr2, f32.min(t0, rn))
  in
  let r = magnitude(z_final) in
  @[0.5 * f32.log(r) * r / dr_final, orbit_min, 0.0]

-- Wrap mb with a time-based rotation about Y.
def scene(p: vec3f32) vec3f32 =
  mb(ry(p, iTime * 0.2))

------------------------------------------------------------
-- Soft shadows — attenuate based on how close the ray came to the
-- surface along its path to the light.
------------------------------------------------------------
def softshadow(ro: vec3f32, rd: vec3f32, k: f32) f32 =
  let (_, _, res) =
    loop (i, t, akuma) = (0, 0.01, 1.0) while i < 50 do
      let h = (scene(ro + rd * t)).x in
      if h < 0.001 then (50, t, 0.02)
      else
        let akuma2 = f32.min(akuma, k * h / t) in
        let tn     = t + clamp(h, 0.01, 2.0) in
        (i + 1, tn, akuma2)
  in res

------------------------------------------------------------
-- Analytic-ish normal via central differences.
------------------------------------------------------------
def nor(p: vec3f32) vec3f32 =
  let e = 0.001 in
  let dx = (scene(@[p.x + e, p.y, p.z])).x - (scene(@[p.x - e, p.y, p.z])).x in
  let dy = (scene(@[p.x, p.y + e, p.z])).x - (scene(@[p.x, p.y - e, p.z])).x in
  let dz = (scene(@[p.x, p.y, p.z + e])).x - (scene(@[p.x, p.y, p.z - e])).x in
  normalize(@[dx, dy, dz])

------------------------------------------------------------
-- Sphere-tracing with overstep (evilryu's "os" trick).
--
-- Returns (res_t, orbit_min_at_best, _). res_t = -1 if no hit.
------------------------------------------------------------
def intersect(ro: vec3f32, rd: vec3f32, pixel_size: f32) vec3f32 =
  let (_, _, _, _, _, _, res_t, res_y) =
    loop (i, t, os, pd, max_err, stop, rt, ry) = (0, 1.0, 0.0, 100.0, 1000.0, false, 0.0, 0.0)
    while i < 48 do
      if stop then (i + 1, t, os, pd, max_err, stop, rt, ry)
      else
        let c = scene(ro + rd * t) in
        let d = c.x in
        let (step, os2, pd2) =
          if d > os then
            let os_new = 0.4 * d * d / pd in
            (d + os_new, os_new, d)
          else
            (0.0 - os, 0.0, 100.0)
        in
        let error = d / t in
        let (max_err2, rt2, ry2) =
          if error < max_err then (error, t, c.y)
          else (max_err, rt, ry)
        in
        let t2 = t + step in
        let stop2 = (error < pixel_size * 0.5) || (t2 > 20.0) in
        (i + 1, t2, os2, pd2, max_err2, stop2, rt2, ry2)
  in
  let final_t = if res_t > 20.0 then 0.0 - 1.0 else res_t in
  @[final_t, res_y, 0.0]

------------------------------------------------------------
-- Full-screen triangle vertex shader
------------------------------------------------------------
def verts: [3]vec4f32 =
  [@[-1.0, -1.0, 0.0, 1.0],
   @[3.0, -1.0, 0.0, 1.0],
   @[-1.0, 3.0, 0.0, 1.0]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 = verts[vertex_id]

------------------------------------------------------------
-- Fragment shader
------------------------------------------------------------
#[fragment]
entry fragment_main(#[builtin(position)] fragCoord: vec4f32) #[location(0)] vec4f32 =
  -- Flip Y for Vulkan.
  let coord = @[fragCoord.x, iResolution.y - fragCoord.y] in
  let q  = @[coord.x / iResolution.x, coord.y / iResolution.y] in
  let uv = @[(0.0 - 1.0 + 2.0 * q.x) * iResolution.x / iResolution.y,
             0.0 - 1.0 + 2.0 * q.y] in
  let pixel_size = 1.0 / (iResolution.x * 3.0) in

  -- Camera orbits using a sin/cos lissajous in (stime, ctime).
  let stime = 0.7 + 0.3 * f32.sin(iTime * 0.4) in
  let ctime = 0.7 + 0.3 * f32.cos(iTime * 0.4) in
  let ta = @[0.0, 0.0, 0.0] in
  let ro = @[0.0, 3.0 * stime * ctime, 3.0 * (1.0 - stime * ctime)] in
  let cf = normalize(ta - ro) in
  let cs = normalize(cross(cf, @[0.0, 1.0, 0.0])) in
  let cu = normalize(cross(cs, cf)) in
  let rd = normalize(cs * uv.x + cu * uv.y + cf * 3.0) in

  -- Lighting directions
  let sundir = normalize(@[0.1, 0.8, 0.6]) in
  let sun    = @[1.64, 1.27, 0.99] in
  let sky    = @[0.6, 1.5, 1.0] in

  -- Background: vertical gradient + sun halo through fog
  let bg0  = @[0.4, 1.6, 1.0] * f32.exp(uv.y - 2.0) in
  let halo = clamp(dot(normalize(@[0.0 - ro.x, 0.0 - ro.y, 0.0 - ro.z]), rd), 0.0, 1.0) in
  let col_bg = bg0 + @[1.0, 0.8, 0.4] * pow(halo, 17.0) in

  -- Trace
  let res = intersect(ro, rd, pixel_size) in
  let col =
    if res.x > 0.0 then
      let p = ro + rd * res.x in
      let n = nor(p) in
      let sh = softshadow(p, sundir, 10.0) in
      let dif = f32.max(0.0, dot(n, sundir)) in
      let skyL = 0.6 + 0.4 * f32.max(0.0, dot(n, @[0.0, 1.0, 0.0])) in
      let bac = f32.max(0.3 + 0.7 * dot(@[0.0 - sundir.x, 0.0 - 1.0, 0.0 - sundir.z], n), 0.0) in
      let spe = f32.max(0.0, pow(clamp(dot(sundir, reflect(rd, n)), 0.0, 1.0), 10.0)) in
      let lin0 = sun * dif * sh * 4.5 in
      let lin1 = lin0 + sun * bac * 0.8 in
      let lin2 = lin1 + sky * skyL * sh * 0.6 in
      let lin3 = lin2 + @[spe, spe, spe] * sh * 3.0 in
      let y = pow(clamp(res.y, 0.0, 1.0), 0.55) in
      let phase = @[3.0 + 4.2 * y + 0.0, 3.0 + 4.2 * y + 0.5, 3.0 + 4.2 * y + 1.0] in
      let tc0 = @[0.5, 0.5, 0.5] + @[f32.sin(phase.x), f32.sin(phase.y), f32.sin(phase.z)] * 0.5 in
      let base = lin3 * @[0.9, 0.8, 0.6] * 0.2 * tc0 in
      -- Fog toward the pure gradient (no halo), matching the GLSL.
      let fog = 1.0 - f32.exp(0.0 - 0.001 * res.x * res.x) in
      mix(base, bg0, fog)
    else
      col_bg
  in

  -- Post-processing: gamma, contrast, desaturation, vignette.
  let c0 = pow(clamp(col, @[0.0, 0.0, 0.0], @[1.0, 1.0, 1.0]), @[0.45, 0.45, 0.45]) in
  let c1 = c0 * 0.6 + c0 * c0 * (@[3.0, 3.0, 3.0] - c0 * 2.0) * 0.4 in
  let gray = dot(c1, @[0.33, 0.33, 0.33]) in
  let c2 = mix(c1, @[gray, gray, gray], 0.0 - 0.5) in
  let v = pow(16.0 * q.x * q.y * (1.0 - q.x) * (1.0 - q.y), 0.7) in
  let c3 = c2 * (0.5 + 0.5 * v) in
  @[c3.x, c3.y, c3.z, 1.0]

