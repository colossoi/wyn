-- "Firefly Meadow" — original Wyn shader
-- A dusk-over-hills scene with two layers of fireflies drifting over
-- silhouetted terrain. Each frame every firefly's brightness is computed
-- via `map`, the ones currently lit are selected with `filter`, and the
-- per-pixel glow is accumulated with `reduce`. Because `filter` returns
-- an OwnedView (sized buffer + runtime count), the downstream `reduce`
-- iterates only over the lit fireflies — the dark ones contribute
-- nothing and don't pay for a `max(brightness, 0)` dance in the kernel.
--
-- Visual elements:
--   * Vertical dusk gradient (warm horizon → indigo zenith).
--   * Horizon silhouette made of two overlaid hill-strips using a
--     low-frequency sinusoidal profile.
--   * Near-layer fireflies: 16, brighter, warmer, drift in small ellipses.
--   * Far-layer fireflies: 24, dimmer, cooler, slower drift.
--   * Subtle stars above the silhouette, filtered by "is above horizon".

------------------------------------------------------------
-- Uniforms
------------------------------------------------------------
#[uniform(set=1, binding=0)] def iResolution: vec3f32
#[uniform(set=1, binding=1)] def iTime: f32

------------------------------------------------------------
-- Vertex shader: full-screen triangle.
------------------------------------------------------------
def verts: [3]vec4f32 =
  [@[-1.0, -1.0, 0.0, 1.0],
   @[ 3.0, -1.0, 0.0, 1.0],
   @[-1.0,  3.0, 0.0, 1.0]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 =
  verts[vertex_id]

------------------------------------------------------------
-- Firefly data (near layer: 16 fireflies)
------------------------------------------------------------

-- Anchor positions in a slightly-wider-than-screen UV space so fireflies
-- can drift off-frame and back. x in [-1.4, 1.4], y in [-0.4, 0.6] so they
-- sit above the hills.
def nearAnchors: [16]vec2f32 = [
  @[-1.25,  0.12], @[-0.95, -0.05], @[-0.75,  0.35], @[-0.45,  0.05],
  @[-0.20,  0.40], @[ 0.05, -0.15], @[ 0.25,  0.25], @[ 0.45,  0.00],
  @[ 0.65,  0.45], @[ 0.85, -0.10], @[ 1.05,  0.30], @[ 1.25,  0.05],
  @[-1.10,  0.50], @[-0.30, -0.20], @[ 0.55, -0.25], @[ 0.95,  0.55]
]

def nearPhases: [16]f32 = [
  0.00, 0.57, 1.13, 1.74, 2.30, 2.89, 3.52, 4.11,
  4.68, 5.27, 0.89, 2.17, 3.33, 4.75, 1.42, 3.98
]

------------------------------------------------------------
-- Firefly data (far layer: 24 fireflies, dimmer/slower)
------------------------------------------------------------

def farAnchors: [24]vec2f32 = [
  @[-1.30,  0.60], @[-1.10,  0.75], @[-0.90,  0.55], @[-0.70,  0.85],
  @[-0.55,  0.65], @[-0.35,  0.80], @[-0.15,  0.70], @[ 0.00,  0.90],
  @[ 0.15,  0.62], @[ 0.35,  0.85], @[ 0.50,  0.55], @[ 0.70,  0.78],
  @[ 0.90,  0.68], @[ 1.10,  0.82], @[ 1.30,  0.60], @[-1.20,  0.40],
  @[-0.80,  0.45], @[-0.40,  0.50], @[ 0.00,  0.48], @[ 0.40,  0.52],
  @[ 0.80,  0.42], @[ 1.20,  0.50], @[-1.00,  0.55], @[ 1.00,  0.55]
]

def farPhases: [24]f32 = [
  0.31, 1.02, 1.78, 2.49, 3.20, 3.91, 4.62, 5.33,
  0.14, 0.85, 1.56, 2.27, 2.98, 3.69, 4.40, 5.11,
  0.48, 1.19, 1.90, 2.61, 3.32, 4.03, 4.74, 5.45
]

------------------------------------------------------------
-- Star data (background stars, filtered by "above horizon")
------------------------------------------------------------

def stars: [20]vec2f32 = [
  @[-1.25,  0.92], @[-1.05,  0.78], @[-0.88,  0.95], @[-0.72,  0.82],
  @[-0.55,  0.90], @[-0.40,  0.76], @[-0.22,  0.88], @[-0.08,  0.94],
  @[ 0.08,  0.80], @[ 0.25,  0.92], @[ 0.42,  0.78], @[ 0.58,  0.85],
  @[ 0.72,  0.95], @[ 0.88,  0.82], @[ 1.05,  0.90], @[ 1.22,  0.76],
  @[-0.60,  0.68], @[-0.15,  0.71], @[ 0.35,  0.68], @[ 0.85,  0.71]
]

def starBrightnesses: [20]f32 = [
  0.85, 0.40, 0.95, 0.55, 0.75, 0.35, 0.65, 0.90,
  0.45, 0.80, 0.50, 0.70, 0.95, 0.60, 0.85, 0.45,
  0.25, 0.30, 0.28, 0.22
]

------------------------------------------------------------
-- Firefly state (drift + blink)
------------------------------------------------------------

-- Near-layer firefly: elliptical drift, faster blink, warm amber color.
def nearState(anchor: vec2f32, phase: f32, t: f32) (vec2f32, f32, vec3f32) =
  let driftT = t * 0.45 + phase in
  let drift = @[f32.sin(driftT) * 0.09,
                f32.sin(driftT * 1.31 + 0.7) * 0.06] in
  let pos = anchor + drift in
  let blink = 0.5 + 0.5 * f32.sin(t * 1.9 + phase * 2.1) in
  let warm = 0.5 + 0.5 * f32.sin(phase * 0.8) in
  let color = @[1.00, 0.82 + warm * 0.10, 0.28 + warm * 0.20] in
  (pos, blink, color)

-- Far-layer firefly: smaller drift, slower blink, cooler color.
def farState(anchor: vec2f32, phase: f32, t: f32) (vec2f32, f32, vec3f32) =
  let driftT = t * 0.18 + phase in
  let drift = @[f32.sin(driftT) * 0.04,
                f32.sin(driftT * 1.17 + 0.3) * 0.03] in
  let pos = anchor + drift in
  let blink = 0.5 + 0.5 * f32.sin(t * 0.85 + phase * 1.6) in
  let cool = 0.5 + 0.5 * f32.sin(phase * 0.5 + 1.3) in
  let color = @[0.75 + cool * 0.20, 0.90, 0.82 + cool * 0.15] in
  (pos, blink, color)

------------------------------------------------------------
-- Per-firefly pixel contribution (inverse-square halo)
------------------------------------------------------------

def nearContribution(uv: vec2f32, pos: vec2f32, brightness: f32, color: vec3f32) vec3f32 =
  let d = magnitude(uv - pos) in
  let core = 0.0018 / (d * d + 0.0002) in
  color * brightness * core

def farContribution(uv: vec2f32, pos: vec2f32, brightness: f32, color: vec3f32) vec3f32 =
  let d = magnitude(uv - pos) in
  let core = 0.0006 / (d * d + 0.00035) in
  color * brightness * 0.6 * core

------------------------------------------------------------
-- Star contribution (tiny hard halo)
------------------------------------------------------------

def starContribution(uv: vec2f32, pos: vec2f32, mag: f32) vec3f32 =
  let d = magnitude(uv - pos) in
  let halo = 0.0002 / (d * d + 0.00015) in
  @[0.90, 0.93, 1.00] * mag * halo

------------------------------------------------------------
-- Horizon silhouette
------------------------------------------------------------

-- Hill profile at horizontal coord x (UV space). Returns the y of the
-- hilltop. Two overlaid sinusoids give a non-repeating silhouette.
def hillProfile(x: f32) f32 =
  let big  = f32.sin(x * 1.3 + 0.4) * 0.18 in
  let mid  = f32.sin(x * 3.1 + 1.7) * 0.07 in
  let fine = f32.sin(x * 7.2 + 2.6) * 0.025 in
  0.0 - 0.30 + big + mid + fine

-- Darker hill layer slightly further back, shifted up.
def farHillProfile(x: f32) f32 =
  let big = f32.sin(x * 0.9 + 1.1) * 0.12 in
  let mid = f32.sin(x * 2.4 + 0.2) * 0.05 in
  0.0 - 0.15 + big + mid

------------------------------------------------------------
-- Sky gradient
------------------------------------------------------------

def duskSky(y: f32) vec3f32 =
  -- y in [-1, 1]: -1 = bottom, 1 = top.
  let t01 = y * 0.5 + 0.5 in
  let horizon = @[0.98, 0.52, 0.28] in
  let mid     = @[0.42, 0.18, 0.38] in
  let zenith  = @[0.06, 0.04, 0.14] in
  if t01 < 0.35 then
    mix(horizon, mid, t01 / 0.35)
  else
    mix(mid, zenith, (t01 - 0.35) / 0.65)

------------------------------------------------------------
-- Hill shading (flat dark with a slight rim at the crest).
------------------------------------------------------------

def hillColor(y: f32, crest: f32) vec3f32 =
  let depth = (crest - y) * 3.0 in
  let baseNear = @[0.08, 0.06, 0.14] in
  let baseFar  = @[0.14, 0.10, 0.22] in
  let base = mix(baseNear, baseFar, f32.max(f32.min(depth, 1.0), 0.0)) in
  let rimGlow = f32.max(1.0 - f32.abs(y - crest) * 60.0, 0.0) in
  let rimColor = @[0.95, 0.45, 0.22] in
  base + rimColor * rimGlow * 0.35

------------------------------------------------------------
-- Fragment shader
------------------------------------------------------------

#[fragment]
entry fragment_main(#[builtin(position)] fragCoord: vec4f32) #[location(0)] vec4f32 =
  -- Compute aspect-corrected UV in [-1, 1] with y up.
  let xy = @[fragCoord.x, iResolution.y - fragCoord.y] in
  let p  = @[(xy.x / iResolution.x) * 2.0 - 1.0,
             (xy.y / iResolution.y) * 2.0 - 1.0] in
  let aspect = iResolution.x / iResolution.y in
  let uv = @[p.x * aspect, p.y] in

  -- Background: dusk sky.
  let sky = duskSky(p.y) in

  -- Determine if we're in a hill or in the sky.
  let nearCrest = hillProfile(uv.x) in
  let farCrest  = farHillProfile(uv.x) in

  let inNearHill = p.y < nearCrest in
  let inFarHill  = p.y < farCrest in

  -- Near-layer fireflies: compute every state, keep only the lit ones,
  -- accumulate their contributions via an explicit loop over the filter's
  -- runtime length. `length(nearLit)` == valid_len on the returned
  -- OwnedView; `nearLit[i]` indexes into its inner buffer.
  let nearStates =
    map(|(anchor, phase): (vec2f32, f32)| nearState(anchor, phase, iTime),
        zip(nearAnchors, nearPhases)) in
  let nearLit =
    filter(|(nearPos, nearBright, nearColor): (vec2f32, f32, vec3f32)| nearBright > 0.55,
           nearStates) in
  let nearN = length(nearLit) in
  let nearGlowLoop =
    loop (acc, i) = (@[0.0, 0.0, 0.0], 0) while i < nearN do
      let (pos, bright, color) = nearLit[i] in
      (acc + nearContribution(uv, pos, bright, color), i + 1)
  in
  let nearGlow = nearGlowLoop.0 in

  -- Far-layer fireflies.
  let farStates =
    map(|(anchor, phase): (vec2f32, f32)| farState(anchor, phase, iTime),
        zip(farAnchors, farPhases)) in
  let farLit =
    filter(|(farPos, farBright, farColor): (vec2f32, f32, vec3f32)| farBright > 0.50,
           farStates) in
  let farN = length(farLit) in
  let farGlowLoop =
    loop (acc, i) = (@[0.0, 0.0, 0.0], 0) while i < farN do
      let (pos, bright, color) = farLit[i] in
      (acc + farContribution(uv, pos, bright, color), i + 1)
  in
  let farGlow = farGlowLoop.0 in

  -- Stars: only render ones whose anchor is above the far hill.
  let starPairs = zip(stars, starBrightnesses) in
  let starsVisible =
    filter(|(starPos, starMag): (vec2f32, f32)| starPos.y > farHillProfile(starPos.x) + 0.02,
           starPairs) in
  let starN = length(starsVisible) in
  let starGlowLoop =
    loop (acc, i) = (@[0.0, 0.0, 0.0], 0) while i < starN do
      let (pos, mag) = starsVisible[i] in
      (acc + starContribution(uv, pos, mag), i + 1)
  in
  let starGlow = starGlowLoop.0 in

  -- Composite: if pixel is in a hill, show only hill color (fireflies are
  -- above the silhouette; stars are above the far hill by construction).
  let skyColor = sky + starGlow + farGlow + nearGlow in
  let color =
    if inNearHill then hillColor(p.y, nearCrest)
    else if inFarHill then mix(hillColor(p.y, farCrest), skyColor, 0.15)
    else skyColor
  in

  let gamma = 1.0 / 2.2 in
  @[color.x ** gamma, color.y ** gamma, color.z ** gamma, 1.0]
