-- Filter with a captured threshold + downstream indexing observation.
-- Exercises:
--  * filter result feeding both `length(...)` (count projection) and
--    `arr[0]` indexing (buffer-member access on the Bounded variant).
--  * a predicate built as a lambda with a closed-over `threshold`,
--    so the EGIR PendingSoac::Filter carries non-empty captures.

def above_threshold(threshold: i32, arr: [6]i32) ?k. [k]i32 =
    filter(|x: i32| x > threshold, arr)

#[vertex]
entry vertex_main() #[builtin(position)] vec4f32 =
    let kept = above_threshold(3, [1, 5, 2, 7, 3, 9]) in
    let count = length(kept) in
    let first = kept[0] in
    @[f32.i32(count), f32.i32(first), 0.0, 1.0]

#[fragment]
entry fragment_main() #[location(0)] vec4f32 =
    @[1.0, 0.0, 0.0, 1.0]
