-- Scene pass: lit 3D ribbons of acko.net's track geometry.
--
-- Geometry comes in as per-vertex attributes from vertex buffers viz
-- uploads — the way the original's `BufferGeometry` does it. Each
-- track's bake covers an extended arc-length range so the shader can
-- slide the visible window through the intro animation without
-- re-baking (the original re-bakes geometry every frame; we cull
-- per-vertex instead).
--
-- Original: Acko.TrackShader + Track.update, reverse-engineered from
-- combo.min.js. Sun + zenith diffuse, half-vector specular, AO blend.

open f32

------------------------------------------------------------
-- Camera — Acko.Effect.Camera at the first-load at-rest state.
--
-- For a first-time visitor the page sits at scroll y=0 (the
-- `a.set(0, pageStart-200)` auto-scroll is gated by `if(!p ...)`
-- and only fires on the returning-visitor non-intro path). The
-- camera-update's `j` clamps to 0, so `J = 0` and the camera lives
-- at its maximally-tilted intro endpoint rather than the
-- straight-on state. Net: position = Y·z_cam + (cam_shift_x, 0, 0)
-- looking at origin, where Y mixes the orbit distance with the
-- perspective constant by M = J*0.8 + 0.2.
--
-- Camera basis rows derived from elevation θ and azimuth φ:
--
--   x_cam = ( cos φ,            0,           -sin φ          )
--   y_cam = (-sin θ·sin φ,    cos θ,         -sin θ·cos φ    )
--   z_cam = ( sin φ·cos θ,    sin θ,          cos φ·cos θ    )
--
-- Tracks are children of the original's `visibleHolder` group, so
-- every track vertex picks up its (0, -10, +200) offset. wgpu
-- clip-space is y-up per the WebGPU spec — positive world y maps
-- straight through to positive clip.y.
------------------------------------------------------------

def x_cam: vec3f32 = @[ 0.8021, 0.0,     0.5972]
def y_cam: vec3f32 = @[ 0.1592, 0.9636, -0.2140]
def z_cam: vec3f32 = @[-0.5754, 0.2667,  0.7731]

-- The `(1-J)*140` shift the original adds to camera x post-lookAt.
def cam_shift_x: f32 = 140.0

-- 1 / tan(fov/2) for fov = 30°.
def fov_f: f32 = 3.7320508

-- Standalone-viz zoom-out factor. The original positions the camera
-- so 1 world unit = 1 pixel at z=0, which keeps the masthead
-- pixel-perfect inside the browser's hero area. In our window that
-- calibration fits only the middle ~half of the model; we pull the
-- camera back. Pure distance change so parallax matches the original.
def zoom_out: f32 = 1.5

-- R^T * v: project a world-space vector onto the camera's basis rows.
def r_transpose_mul(v: vec3f32) vec3f32 =
  @[dot(x_cam, v), dot(y_cam, v), dot(z_cam, v)]

def view_transform(p: vec3f32, view_height: f32) vec3f32 =
  let perspective_v = 1.866 * view_height in
  let cam_dist      = (1200.0 + (perspective_v - 1200.0) * 0.2) * zoom_out in
  let cam_pos       = cam_dist * z_cam + @[cam_shift_x, 0.0, 0.0] in
  let w             = @[p.x, p.y - 10.0, p.z + 200.0] in
  r_transpose_mul(w - cam_pos)

def perspective_project(v: vec3f32, aspect: f32) vec4f32 =
  let near = 2.0 in
  let far = 17000.0 in
  let cx = fov_f * v.x / aspect in
  let cy = fov_f * v.y in
  -- Vulkan clip-space z ∈ [0, w]; w = -view_z for perspective divide.
  let neg_tz = 0.0 - v.z in
  let cz = (far / (far - near)) * neg_tz + (0.0 - far * near / (far - near)) in
  let cw = neg_tz in
  @[cx, cy, cz, cw]

-- For a pure-rotation R, R^T·d gives the direction in the camera's frame.
def world_to_view_dir(d: vec3f32) vec3f32 = r_transpose_mul(d)

------------------------------------------------------------
-- Intro animation: the H(t) curve from combo.min.js's Track.update
--
--   H_raw = max(0, (duration - t) / bend)
--   H     = (H_raw < 0.5 ? H_raw^2 : H_raw - 0.25) * bend
--   travel(t) = initial - H(t) * speed
--
-- The smoothing is C1 at H_raw = 0.5 (both halves give 0.25 * bend
-- there with matching slopes). At t=0, H = duration - 0.25*bend, so
-- the visible window starts (duration - 0.25*bend) * speed worth of
-- arc-length BEFORE `initial`. After `duration`, H = 0 and the
-- masthead is static forever (the original zeros out speed/distance
-- at that point; we just leave the formula at H=0).
--
-- Per-vertex `vert_s` is arc-length relative to the track's `initial`
-- (so 0 means "at the rest start"). Per-vertex `track_meta` holds
-- (speed, bend, duration, length) for that vertex's track.
------------------------------------------------------------

def smooth_h(h_raw: f32, bend: f32) f32 =
  if h_raw < 0.5 then h_raw * h_raw * bend
  else (h_raw - 0.25) * bend

def t_offset(time: f32, speed: f32, bend: f32, duration: f32) f32 =
  let h_raw  = max(0.0, (duration - time) / bend) in
  let h      = smooth_h(h_raw, bend) in
  0.0 - h * speed

------------------------------------------------------------
-- Vertex shader
--
--   Inputs (per-vertex):
--     slot 0: position     (x, y, z, ao)
--     slot 1: normal       (nx, ny, nz, _)
--     slot 2: vertex_color (r, g, b, _)
--     slot 3: vert_s       arc-length offset from track's `initial`
--     slot 4: track_meta   (speed, bend, duration, length)
--
--   Outputs (varyings):
--     varying 0: view-space normal (un-normalized — the rasterizer's
--                 interpolation produces nlen < 1 across facets, which
--                 the fragment shader uses for the silhouette/outline
--                 term and for silhouette darkening on the zenith dot).
--     varying 1: vertex color
--     varying 2: AO factor
--     varying 3: view-space position (camera at origin in this frame,
--                 so length(view_pos) is the per-fragment distance —
--                 used for fog).
--
-- For visible vertices (vert_s ∈ [t_offset, t_offset + length]),
-- output normal clip-space position. For culled vertices, push clip.z
-- to a huge multiple of clip.w so the GPU's far-plane clip collapses
-- every boundary triangle to ~zero area — the cleanest cull achievable
-- without a fragment-discard intrinsic.
------------------------------------------------------------
#[vertex]
entry vertex_main
  ( #[vertex_slot(0)] position    : vec4f32
  , #[vertex_slot(1)] normal      : vec4f32
  , #[vertex_slot(2)] vertex_color: vec4f32
  , #[vertex_slot(3)] vert_s      : f32
  , #[vertex_slot(4)] track_meta  : vec4f32
  , #[uniform(set=1, binding=0)] iResolution: vec3f32
  , #[uniform(set=1, binding=1)] iTime: f32
  )
  ( #[builtin(position)] vec4f32
  , #[varying(0)] vec3f32  -- view-space normal (un-normalized)
  , #[varying(1)] vec3f32  -- color
  , #[varying(2)] f32      -- AO
  , #[varying(3)] vec3f32  -- view-space position
  ) =
  let world    = @[position.x, position.y, position.z] in
  let n_world  = @[normal.x, normal.y, normal.z] in
  let n_view   = world_to_view_dir(n_world) in
  let color    = @[vertex_color.x, vertex_color.y, vertex_color.z] in
  let @[speed, bend, duration, length] = track_meta in
  let off      = t_offset(iTime, speed, bend, duration) in
  let in_window = vert_s >= off && vert_s <= off + length in
  let view_pos = view_transform(world, iResolution.y) in
  let aspect   = iResolution.x / iResolution.y in
  let clip     = perspective_project(view_pos, aspect) in
  let cull_z   = if in_window then clip.z else 1.0e8 * clip.w in
  (@[clip.x, clip.y, cull_z, clip.w], n_view, color, position.w, view_pos)

------------------------------------------------------------
-- Fragment shader — port of Acko.TrackShader (combo.min.js).
--
-- Lighting in view space: the rasterizer hands us interpolated
-- un-normalized normals (length < 1 between vertices with
-- differing normals — i.e., at silhouettes), which the shader
-- exploits for two effects:
--   1. `dz` uses the un-normalized normal so silhouettes get less
--      zenith contribution (darker silhouette band).
--   2. `outline = clamp(3 - nlen²·3, 0, 1)` ramps up at nlen<1 and
--      brightens the body color, the comic-book outline look.
--
-- Diffuse range is compressed (`d*0.5 + 0.5`) so the shaded side
-- floors at 0.5 rather than going to black — gives the bright,
-- desaturated look of the original instead of harsh Lambert.
--
-- Fog mixes the lit color toward white (= the viz clear color)
-- starting at distance 2200, so distant geometry fades into the
-- background.
------------------------------------------------------------

def sat_clamp(x: f32) f32 = clamp(x, 0.0, 1.0)

-- Sun + zenith in view space, precomputed: R^T applied to world
-- direction. Sun world (0.416, 0.371, 0.619) is intentionally NOT
-- normalized — the original TrackShader uses `vec3(.416, .371, .619)`
-- as a length-0.833 vector, so all diffuse dots scale by that factor.
-- Zenith world (0, 1, 0) is unit.
def sun_view: vec3f32 = @[0.7034, 0.2912, 0.3380]
def zenith_view: vec3f32 = @[0.0, 0.9636, 0.2667]

#[fragment]
entry fragment_main
  ( #[varying(0)] n_in    : vec3f32
  , #[varying(1)] color   : vec3f32
  , #[varying(2)] ao      : f32
  , #[varying(3)] view_pos: vec3f32
  ) #[target(screen)] vec4f32 =
  let n_norm = normalize(n_in) in

  -- Diffuse: sun with normalized N, zenith with un-normalized N
  -- (silhouettes darken because nlen < 1 reduces the dot product).
  let ds = sat_clamp(dot(n_norm, sun_view)) in
  let dz = sat_clamp(dot(n_in,   zenith_view)) in
  let diff0 = ds * @[1.5, 1.0, 0.7] + dz * @[0.1, 0.4, 0.5] in

  -- Range compression (original's `diffuse = diffuse*0.5 + 0.5`,
  -- with ambientCorrection=0): floors the dark side at 0.5.
  let diff = diff0 * 0.5 + @[0.5, 0.5, 0.5] in

  -- Silhouette outline boost.
  let nlen2 = dot(n_in, n_in) in
  let outline = clamp(3.0 - nlen2 * 3.0, 0.0, 1.0) in
  let outline_mult = 1.0 + outline * 0.35 in

  -- Half-vector specular. Camera is at origin in view space, so the
  -- direction toward the camera is normalize(-view_pos).
  let view_dir = normalize(0.0 - view_pos) in
  let half     = normalize(sun_view + view_dir) in
  let spec     = pow(sat_clamp(dot(n_norm, half)), 4.0) in
  let spec_col = vec.sqrt(color) * 0.15 in

  -- AO mix by luminance: dark regions get tinted by the base color,
  -- lit regions stay near-white.
  let lum     = dot(diff, @[0.299, 0.587, 0.114]) in
  let ao_dark = (ao * ao + ao) * 0.5 in
  let bright  = ao * lum in
  let ao_vec  = color * (ao_dark * (1.0 - lum)) + @[bright, bright, bright] in

  let lit = ao_vec * (diff * color * outline_mult + spec * spec_col) in

  -- Distance-based fog blending the lit color toward white. The
  -- 2200 cut-in / 0.00022 falloff are the original's tunings — fog
  -- begins around the model's far edge and reaches the background
  -- at typical screen-edge distances.
  let view_dist = sqrt(dot(view_pos, view_pos)) in
  let fog       = sat_clamp(exp(0.0 - (view_dist - 2200.0) * 0.00022)) in
  let fog_col   = @[1.0 - fog, 1.0 - fog, 1.0 - fog] + lit * fog in

  -- sqrt = pow(x, 1/2): cheap linear→sRGB gamma encoding.
  let out = vec.sqrt(fog_col) in
  @[out.x, out.y, out.z, 1.0]
