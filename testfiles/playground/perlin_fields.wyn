-- "Perlin Noise Fields" — a flow-field particle painter.
--
-- Faithful to Manohar Vanga's "Getting Creative with Perlin Noise Fields"
-- (https://sighack.com/post/getting-creative-with-perlin-noise-fields,
-- MIT-licensed sketches at https://github.com/sighack/perlin-noise-fields):
-- particles spawn at random, each frame read a flow angle
--
--     theta = noise(x * scale, y * scale) * 2pi
--
-- from a Perlin field, step one unit along (cos theta, sin theta), and drop a
-- texel into a persistent canvas. The canvas is never cleared, so the
-- particles' paths accumulate into the dense, hair-like curves the original
-- draws. Particles respawn at a fresh random spot when they age out or leave
-- the frame, so coverage keeps building. The field `noise()` is 4-octave fbm
-- (Processing's default), supplied here by `lib/noise.wyn`'s `fbm_perlin`.
--
-- This is the real technique, not a per-pixel approximation: a state
-- feedback loop (`tick`) + a scatter rasterizer (`rasterize`) + a display
-- pass, the same architecture as `particles.wyn`.
--
-- Hold a lowercase letter to choose the field's angle transform; the canvas
-- keeps accumulating, so switching overlays the new field on the old. Restart
-- viz for a clean canvas.
--
--   a  classic field            theta = fbm * 2pi
--   b  right angles             theta snapped to the nearest 90 degrees
--   c  swirl                    theta = fbm * 2pi * 3   (tighter vortices)
--   d  perpendicular            theta + 90 degrees      (field rotated a quarter turn)
--   e  drift                    field translates over time (animated)
--   f  fine scale               higher noise frequency   (busier field)
--
-- Fidelity note: the original blends each texel with low alpha so paths build
-- up soft density gradients. `scatter` overwrites (last writer wins per pixel),
-- so trails here are solid colored curves rather than gradient washes —
-- additive blending needs a read-modify-write the scatter rasterizer can't
-- express yet.
--
-- Run (canvas is RES x RES = 720 x 720; size the window to match):
--   cargo run --bin wyn -- compile testfiles/playground/perlin_fields.wyn -o /tmp/pf.spv
--   (cd extra/viz && cargo run -- pipeline /tmp/pf.spv \
--       --feedback tick:prev=tick_output \
--       --buffer-init fb:8294400:0 \
--       --size 720x720)
--   (fb bytes = RES*RES * sizeof(vec4f32) = 720*720*16 = 8294400)

import "../../lib/noise"
import "../../lib/rng"

open f32

-- N is kept modest on purpose: the per-particle `map` in `tick` and the
-- `scatter` in `rasterize` both lower to a serial loop with no per-thread
-- partition, yet the host dispatches one thread per particle — so each frame
-- costs O(N^2). At a few thousand particles that trips the GPU watchdog (white
-- screen / hang). The canvas accumulates across frames, so ~1k particles still
-- paint dense curves over a few hundred frames. Bump this only once the map /
-- scatter lowering is parallelized.
def N: i32 = 1024
def RES: i32 = 720
def RESF: f32 = 720.0
def STEP: f32 = 1.5
def LIFETIME: f32 = 120.0
def NOISE_SCALE: f32 = 0.009
-- 4-octave / gain-0.5 fbm sums to roughly +/- (1-0.5^4)/(1-0.5); the
-- reciprocal renormalizes one sample back into [-1, 1].
def INV_FBM: f32 = 0.53333
def TWO_PI: f32 = 6.28318530718
def FIELD_SEED: u32 = 1337

------------------------------------------------------------
-- rng helpers (lib/rng.wyn fasthash) — uniform f32 in [0, 1).
------------------------------------------------------------

def rand01(key: u32, pos: u32) f32 =
  f32.u32(fasthash.at_u32(key, pos) >> 8u32) * (1.0 / 16777216.0)

-- A fresh particle at a hashed random position, age 0, carrying a random
-- "tint" seed in .w. `salt` decorrelates the per-particle streams.
def spawn(i: i32, salt: u32) vec4f32 =
  let key = fasthash.seed(u32.i32(i) * 2654435761u32 + salt) in
  @[rand01(key, 0u32) * RESF, rand01(key, 1u32) * RESF, 0.0, rand01(key, 2u32)]

------------------------------------------------------------
-- the flow field: 4-octave fbm perlin → angle, per the chosen variant.
------------------------------------------------------------

def fbm01(p: vec2f32) f32 =
  let k = fasthash.seed(FIELD_SEED) in
  fhnoise.fbm_perlin(k, p, 4i32, 2.0, 0.5) * INV_FBM * 0.5 + 0.5

def field_angle(pos: vec2f32, variant: i32, t: f32) f32 =
  let base = fbm01(pos * NOISE_SCALE) * TWO_PI in
  if variant == 1i32 then
    floor(base / (pi * 0.5) + 0.5) * (pi * 0.5)
  else if variant == 2i32 then
    fbm01(pos * NOISE_SCALE) * TWO_PI * 3.0
  else if variant == 3i32 then
    base + pi * 0.5
  else if variant == 4i32 then
    fbm01(pos * NOISE_SCALE + @[t * 0.05, t * 0.03]) * TWO_PI
  else if variant == 5i32 then
    fbm01(pos * (NOISE_SCALE * 2.5)) * TWO_PI
  else
    base

-- Advance one particle: step along the field, age it, respawn when it ages
-- out or leaves the frame.
def step_particle(p: vec4f32, i: i32, frame: u32, variant: i32, t: f32) vec4f32 =
  let pos = @[p.x, p.y] in
  let theta = field_angle(pos, variant, t) in
  let npos = pos + @[cos(theta), sin(theta)] * STEP in
  let nage = p.z + 1.0 in
  let inb = npos.x >= 0.0 && npos.x < RESF && npos.y >= 0.0 && npos.y < RESF in
  if nage > LIFETIME || !inb then spawn(i, frame * 40503u32 + 7u32)
  else @[npos.x, npos.y, nage, p.w]

------------------------------------------------------------
-- keyboard variant select (Shadertoy 256×3 layout; row 0 = held).
------------------------------------------------------------

def held(keyboard: []u32, code: i32) bool = keyboard[0i32 * 256i32 + code] != 0u32

def select_variant(keyboard: []u32) i32 =
  if held(keyboard, 66i32) then 1i32        -- b
  else if held(keyboard, 67i32) then 2i32   -- c
  else if held(keyboard, 68i32) then 3i32   -- d
  else if held(keyboard, 69i32) then 4i32   -- e
  else if held(keyboard, 70i32) then 5i32   -- f
  else 0i32                                 -- a (default)

------------------------------------------------------------
-- tick: the simulation. State feedback loop over the particle buffer.
------------------------------------------------------------

#[compute]
entry tick(#[storage(set=2, binding=0, access=read)] prev: []vec4f32,
           #[storage(set=2, binding=2, access=read)] keyboard: []u32,
           #[uniform(set=1, binding=1)] iTime: f32,
           #[uniform(set=1, binding=3)] iFrame: u32) []vec4f32 =
  if iTime < 0.1 then
    -- Stagger initial ages so particles don't all respawn in lockstep.
    map(|i: i32|
          let s = spawn(i, 11u32) in
          @[s.x, s.y, rand01(fasthash.seed(u32.i32(i) + 99u32), 0u32) * LIFETIME, s.w],
        0i32 ..< N)
  else
    let variant = select_variant(keyboard) in
    let ps = prev[0..N] in
    map(|i: i32| step_particle(ps[i], i, iFrame, variant, iTime), 0i32 ..< N)

------------------------------------------------------------
-- rasterize: scatter one tinted texel per particle into the persistent
-- canvas. `fb` is never cleared, so paths accumulate into curves.
------------------------------------------------------------

-- Iñigo Quilez cosine palette — warm flow tints keyed off the particle seed.
def tint(seed: f32) vec4f32 =
  let d = @[0.0, 0.15, 0.35] in
  let kk = TWO_PI * (seed + d) in
  let c = @[0.55, 0.45, 0.4] + @[0.45, 0.4, 0.4] * @[cos(kk.x), cos(kk.y), cos(kk.z)] in
  @[c.x, c.y, c.z, 1.0]

def clampi(v: i32) i32 = if v < 0i32 then 0i32 else if v >= RES then RES - 1i32 else v

#[compute]
entry rasterize(#[storage(set=2, binding=0, access=read)] positions: []vec4f32,
                #[storage(set=2, binding=1, access=write)] fb: []vec4f32) () =
  let ps = positions[0..N] in
  let idxs = map(|i: i32|
                   let p = ps[i] in
                   clampi(i32.f32(p.y)) * RES + clampi(i32.f32(p.x)),
                 0i32 ..< N) in
  let vals = map(|i: i32| tint(ps[i].w), 0i32 ..< N) in
  let _ = scatter(fb, idxs, vals) in ()

------------------------------------------------------------
-- display: sample the canvas at the pixel's flat index.
------------------------------------------------------------

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vid: i32) #[builtin(position)] vec4f32 =
  let x = if vid == 0i32 then -1.0 else if vid == 1i32 then 3.0 else -1.0 in
  let y = if vid == 0i32 then -1.0 else if vid == 1i32 then -1.0 else 3.0 in
  @[x, y, 0.0, 1.0]

#[fragment]
entry main_image(#[storage(set=2, binding=1, access=read)] fb: []vec4f32,
                 #[builtin(position)] fragCoord: vec4f32) #[target(screen)] vec4f32 =
  let x = clampi(i32.f32(fragCoord.x)) in
  let y = clampi(i32.f32(fragCoord.y)) in
  fb[y * RES + x]
