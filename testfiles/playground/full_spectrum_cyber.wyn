--     p -= vec2(clamp(p.x, -k.z*r, k.z*r), r);
--     return length(p)*sign(p.y);
-- }
--
-- float hex(vec2 p) {
--     p.x *= 0.57735*2.0;
-- 	p.y+=mod(floor(p.x),2.0)*0.5;
