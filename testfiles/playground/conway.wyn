-- Conway's Game of Life.
--
-- Two entry points:
--
--   `step`    (compute) — reads the current generation from a storage
--                         buffer, writes the next generation to the
--                         return buffer. The host dispatches this once
--                         per frame, ping-ponging input/output bindings.
--
--   `display` (fragment) — reads the most-recently-written buffer via a
--                          module-scope storage binding and colors each
--                          pixel by the cell it falls on.
--
-- The loop itself lives in the host: each frame it dispatches `step`
-- and then renders with `display`, swapping which physical buffer is
-- bound where. Nothing in Wyn is simulating "time" — the Wyn file
-- describes the per-step rule and the per-pixel rendering; the driver
-- iterates them.

-- ---------------------------------------------------------------
-- Shared helpers
-- ---------------------------------------------------------------

-- Read cell (x, y) from a flat row-major board. Cells outside the
-- grid are treated as dead (0), so the universe is bounded by dead
-- walls on every side.
def cell(board: []i32, width: i32, height: i32, x: i32, y: i32) i32 =
    if x < 0 then 0
    else if x >= width then 0
    else if y < 0 then 0
    else if y >= height then 0
    else board[y * width + x]

-- Count the 8 Moore-neighborhood neighbors of (x, y).
def neighbor_count(board: []i32, width: i32, height: i32, x: i32, y: i32) i32 =
    cell(board, width, height, x - 1, y - 1) +
    cell(board, width, height, x,     y - 1) +
    cell(board, width, height, x + 1, y - 1) +
    cell(board, width, height, x - 1, y    ) +
    cell(board, width, height, x + 1, y    ) +
    cell(board, width, height, x - 1, y + 1) +
    cell(board, width, height, x,     y + 1) +
    cell(board, width, height, x + 1, y + 1)

-- Conway's rule applied to a single flat index.
def step_cell(board: []i32, width: i32, height: i32, i: i32) i32 =
    let x = i % width in
    let y = i / width in
    let n = neighbor_count(board, width, height, x, y) in
    let alive = board[i] == 1 in
    if alive then
        if n == 2 || n == 3 then 1 else 0
    else if n == 3 then 1 else 0

-- ---------------------------------------------------------------
-- Compute entry: one Conway step over the whole grid
-- ---------------------------------------------------------------

#[compute]
entry step(board: []i32, width: i32, height: i32) []i32 =
    map(|i| step_cell(board, width, height, i), iota(length(board)))

-- ---------------------------------------------------------------
-- Fragment entry: render the current board
-- ---------------------------------------------------------------

def verts: [3]vec4f32 =
    [@[-1.0, -1.0, 0.0, 1.0],
     @[ 3.0, -1.0, 0.0, 1.0],
     @[-1.0,  3.0, 0.0, 1.0]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 =
    verts[vertex_id]

#[fragment]
entry display(#[uniform(set = 1, binding = 0)] iResolution: vec3f32, #[uniform(set = 1, binding = 1)] grid_width: i32, #[uniform(set = 1, binding = 2)] grid_height: i32, #[storage(set = 1, binding = 3, access = read)] display_board: []i32, #[builtin(position)] fragCoord: vec4f32) #[location(0)] vec4f32 =
    -- Flip Y so (0, 0) renders at the top-left visually.
    let px = fragCoord.x in
    let py = iResolution.y - fragCoord.y in

    let cell_w = iResolution.x / f32.i32(grid_width) in
    let cell_h = iResolution.y / f32.i32(grid_height) in

    let gx = i32.f32(px / cell_w) in
    let gy = i32.f32(py / cell_h) in

    if gx < 0 || gx >= grid_width || gy < 0 || gy >= grid_height then
        @[0.1, 0.1, 0.1, 1.0]
    else
        let idx = gy * grid_width + gx in
        let alive = display_board[idx] == 1 in
        if alive then @[1.0, 1.0, 1.0, 1.0] else @[0.0, 0.0, 0.0, 1.0]
