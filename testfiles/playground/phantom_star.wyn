-- "Phantom Star" by kasari39 — Wyn port of the CineShader / Shadertoy shader.
-- Volumetric ray-march through an IFS fractal box field, accumulating
-- glow into a blue/cyan color using "Phantom Mode" by aiekick.
-- Original: https://www.shadertoy.com/view/MtScWW (Phantom Mode by aiekick)
-- The original GLSL is preserved commented-out below.

open f32

------------------------------------------------------------
-- Uniforms
------------------------------------------------------------
#[uniform(set=1, binding=0)] def iResolution: vec3f32
#[uniform(set=1, binding=1)] def iTime: f32

------------------------------------------------------------
-- Constants
------------------------------------------------------------
def PI: f32 = 3.14159265358979
def PI2: f32 = PI * 2.0

------------------------------------------------------------
-- Vertex shader: full-screen triangle
------------------------------------------------------------
def verts: [3]vec4f32 =
  [@[-1.0, -1.0, 0.0, 1.0],
   @[3.0, -1.0, 0.0, 1.0],
   @[-1.0, 3.0, 0.0, 1.0]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 =
  verts[vertex_id]

------------------------------------------------------------
-- 2D rotation matrix.
-- `@[[c, s], [-s, c]]` — outer arrays become SPIR-V columns at
-- emission, so this represents the matrix [[c, -s], [s, c]] —
-- identical to GLSL `mat2(c, s, -s, c)`.
------------------------------------------------------------
def rot(a: f32) mat2f32 =
  let c = cos(a) in
  let s = sin(a) in
  @[[c, s], [0.0 - s, c]]

------------------------------------------------------------
-- Polar modulo: angular symmetry of order r around origin.
-- GLSL: atan(p.x, p.y) → atan2(x, y)
------------------------------------------------------------
def pmod(p: vec2f32, r: f32) vec2f32 =
  let a = atan2(p.x, p.y) + PI / r in
  let n = PI2 / r in
  let a2 = floor(a / n) * n in
  p * rot(0.0 - a2)

------------------------------------------------------------
-- Box SDF.
-- Returns signed distance to axis-aligned box centered at origin
-- with half-extents b.
------------------------------------------------------------
def box(p: vec3f32, b: vec3f32) f32 =
  let d = @[abs(p.x) - b.x, abs(p.y) - b.y, abs(p.z) - b.z] in
  let inside = min(max(d.x, max(d.y, d.z)), 0.0) in
  -- Element-wise max with zero (can't use overloaded max with open f32)
  let dpos = @[max(d.x, 0.0), max(d.y, 0.0), max(d.z, 0.0)] in
  let outside = magnitude(dpos) in
  inside + outside

------------------------------------------------------------
-- IFS (Iterated Function System) box.
-- Five rounds of abs-fold + rotation, then a final xz rotation,
-- then evaluate the box SDF.
------------------------------------------------------------
def ifsBox(p0: vec3f32) f32 =
  let p_folded =
    loop p = p0 for i < 5 do
      let p1 = @[abs(p.x) - 1.0, abs(p.y) - 1.0, abs(p.z) - 1.0] in
      let p2 = p1 with .xy *= rot(iTime * 0.3) in
      let p3 = p2 with .xz *= rot(iTime * 0.1) in
      p3
  in
  let pf = p_folded with .xz *= rot(iTime) in
  box(pf, @[0.4, 0.8, 0.3])

------------------------------------------------------------
-- Scene SDF.
-- Folds space modularly in x, y, z and applies polar symmetry on xy.
------------------------------------------------------------
def sceneMap(p: vec3f32) f32 =
  let px = mod(p.x - 5.0, 10.0) - 5.0 in
  let py = mod(p.y - 5.0, 10.0) - 5.0 in
  let pz = mod(p.z, 16.0) - 8.0 in
  let p1: vec3f32 = @[px, py, pz] in
  let pxy2 = pmod(@[p1.x, p1.y], 5.0) in
  let p2: vec3f32 = @[pxy2.x, pxy2.y, p1.z] in
  ifsBox(p2)

------------------------------------------------------------
-- Fragment shader
------------------------------------------------------------
#[fragment]
entry fragment_main(#[builtin(position)] fragCoord: vec4f32) #[location(0)] vec4f32 =
  -- Flip Y for Vulkan so the screen-Y convention matches Shadertoy's.
  let fc = @[fragCoord.x, iResolution.y - fragCoord.y] in
  -- Screen-space UV ([-1,1] range, aspect-corrected)
  let p = (fc * 2.0 - iResolution.xy) / min(iResolution.x, iResolution.y) in

  -- Camera setup: flying forward along -Z
  let cPos  = @[0.0, 0.0, 0.0 - 3.0 * iTime] in
  let cDir  = normalize(@[0.0, 0.0, 0.0 - 1.0]) in
  let cUp   = @[sin(iTime), 1.0, 0.0] in
  let cSide = cross(cDir, cUp) in
  let ray   = normalize(cSide * p.x + cUp * p.y + cDir) in

  -- Volumetric ray march (Phantom Mode by aiekick)
  -- Accumulates two glow channels: acc (base) and acc2 (pulse rings).
  let (acc, acc2, t) =
    loop (acc, acc2, t) = (0.0, 0.0, 0.0) for i < 99 do
      let pos  = cPos + ray * t in
      let dist = max(abs(sceneMap(pos)), 0.02) in
      let a    = exp(0.0 - dist * 3.0) in
      -- Pulse rings: every 30 units (modulated by time) double the
      -- glow contribution `a` and add it to BOTH acc and acc2. The
      -- GLSL is `a *= 2; acc2 += a; ... acc += a;` so the doubled
      -- value also lands in the primary glow channel.
      let in_ring   = mod(magnitude(pos) + 24.0 * iTime, 30.0) < 3.0 in
      let (a_eff, acc2_next) =
        if in_ring then let doubled = a * 2.0 in (doubled, acc2 + doubled)
        else (a, acc2) in
      (acc + a_eff, acc2_next, t + dist * 0.5)
  in

  let col = @[acc * 0.01, acc * 0.011 + acc2 * 0.002, acc * 0.012 + acc2 * 0.005] in
  @[col.x, col.y, col.z, 1.0 - t * 0.03]

