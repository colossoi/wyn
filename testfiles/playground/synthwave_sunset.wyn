-- "another synthwave sunset thing" by fad (Shadertoy) — Wyn port of the Shadertoy shader.
-- Procedural synthwave landscape: triangular-grid terrain noise, ray-marched ground,
-- star field, purple sky with animated sun disc, and retro magenta terrain coloring.
-- Original: https://www.shadertoy.com/view/WXsGzs (author: fad)
-- The original GLSL is preserved commented-out below.
--
-- NOTE: `disable_sound_texture_sampling` is active in the original, so all
-- textureMirror calls return zero — dropped entirely in this port.
-- NOTE: `iTimeDelta` is not a standard Wyn uniform; we use a fixed dt=0.0 for
-- the motion-blur jitter (no per-frame temporal delta available).
-- NOTE: The ray-march loop is capped at 100 iterations (original: 500).
-- NOTE: The starnoise mat3 rotation is inlined as a closed-form linear transform.
-- NOTE: AA (anti-aliasing) and stereo modes are disabled (as in the original defaults).

open f32

#[uniform(set=1, binding=0)] def iResolution: vec3f32
#[uniform(set=1, binding=1)] def iTime: f32

def SPEED: f32 = 10.0

------------------------------------------------------------
-- Full-screen triangle vertex shader
------------------------------------------------------------
def verts: [3]vec4f32 =
  [@[-1.0, -1.0, 0.0, 1.0],
   @[3.0,  -1.0, 0.0, 1.0],
   @[-1.0,  3.0, 0.0, 1.0]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 =
  verts[vertex_id]

------------------------------------------------------------
-- Math helpers
------------------------------------------------------------

-- a^512 via repeated squaring (used for sharp star/sun cutoffs)
def pow512(a: f32) f32 =
  let a2  = a   * a   in
  let a4  = a2  * a2  in
  let a8  = a4  * a4  in
  let a16 = a8  * a8  in
  let a32 = a16 * a16 in
  let a64 = a32 * a32 in
  let a128 = a64 * a64 in
  let a256 = a128 * a128 in
  a256 * a256

-- a^1.5 = a * sqrt(a)
def pow1d5(a: f32) f32 = a * sqrt(a)

-- 2D hash → [0,1)
def hash21(co: vec2f32) f32 =
  fract(sin(dot(co, @[1.9898, 7.233])) * 45758.5433)

------------------------------------------------------------
-- Terrain noise (triangular grid)
------------------------------------------------------------

-- Amplitude envelope: zero inside [-1,1] in x, ramps to full outside ±8
def amp_fn(p: vec2f32) f32 =
  smoothstep(1.0, 8.0, abs(p.x))

-- Hash with wave-modulation (wave_thing enabled)
def hash_terrain(uv: vec2f32, jt: f32) f32 =
  let a = amp_fn(uv) in
  if a > 0.0
  then
    let wave_phase = (0.02 * (uv.y + 0.5 * uv.x) - jt) * 2.0 in
    let w = 1.0 - 0.4 * pow512(0.51 + 0.49 * sin(wave_phase)) in
    a * pow1d5(hash21(uv)) * w
  else 0.0

-- Edge sharpness for the triangular grid wireframe.
-- The original used `textureMirror` lookups on the three triangle-corner
-- hashes to colour-tint the edges; with sound-texture sampling
-- disabled, those all return zero, the a-weights collapse to 1, and
-- the corner-hash computation is dead. Only the geometric edge
-- distance remains.
def edgeMin(dx: f32, da: vec2f32, db: vec2f32, _uv: vec2f32) f32 =
  min(min((1.0 - dx) * db.y, da.x), da.y)

-- Triangular-grid value noise: returns (height, edge_mask)
def trinoise(uv_in: vec2f32, jt: f32) (f32, f32) =
  let sq = sqrt(1.5) in
  let uv0 = @[uv_in.x * sq, uv_in.y - 0.5 * uv_in.x * sq] in
  let d  = vec.fract(uv0) in
  let uv = @[uv0.x - d.x, uv0.y - d.y] in
  let is_upper = dot(d, @[1.0, 1.0]) > 1.0 in
  let dd = @[1.0 - d.x, 1.0 - d.y] in
  let n2 = hash_terrain(@[uv.x + 1.0, uv.y], jt) in
  let n3 = hash_terrain(@[uv.x, uv.y + 1.0], jt) in
  let (da, db, corner_off, n_alt) =
    if is_upper then (dd, d, 1.0, n2)
    else (d, dd, 0.0, n3) in
  let nn = hash_terrain(@[uv.x + corner_off, uv.y + corner_off], jt) in
  let nmid = mix(n2, n3, d.y) in
  let ns   = mix(nn, n_alt, da.y) in
  let dx   = da.x / db.y in
  (mix(ns, nmid, dx), edgeMin(dx, da, db, @[uv.x + d.x, uv.y + d.y]))

------------------------------------------------------------
-- Scene SDF (terrain)
------------------------------------------------------------

-- Returns (signed-distance, edge_mask)
def scene_map(p: vec3f32, jt: f32) (f32, f32) =
  let (h, e) = trinoise(@[p.x, p.z], jt) in
  (p.y - 2.0 * h, e)

-- Gradient via central finite differences (for surface normal)
def grad3(p: vec3f32, jt: f32) vec3f32 =
  let e = 0.005 in
  let a = (scene_map(p, jt)).0 in
  let gx = (scene_map(@[p.x + e, p.y, p.z], jt)).0 - a in
  let gy = (scene_map(@[p.x, p.y + e, p.z], jt)).0 - a in
  let gz = (scene_map(@[p.x, p.y, p.z + e], jt)).0 - a in
  @[gx / e, gy / e, gz / e]

------------------------------------------------------------
-- Ray-marcher (500 steps to match the original).
------------------------------------------------------------

-- Returns (ray_t, edge_mask); ray_t < 0 means sky.
def intersect(ro: vec3f32, rd: vec3f32, jt: f32) (f32, f32) =
  let (_, d_final, _, edge_final, hit, _) =
    loop (i, d, h, edge, hit, done) = (0, 0.0, 0.0, 0.0, false, false)
    while i < 500 && !done do
      let p = @[ro.x + d * rd.x, ro.y + d * rd.y, ro.z + d * rd.z] in
      let (s, e) = scene_map(p, jt) in
      let d2 = d + s * 0.5 in
      let converged = abs(s) < 0.003 * d2 in
      let escaped   = d2 > 150.0 || p.y > 2.0 in
      (i + 1, d2, s, e, converged, converged || escaped)
  in
  if hit then (d_final, edge_final) else (-1.0, -1.0)

------------------------------------------------------------
-- Sun disc
------------------------------------------------------------

def addsun(rd: vec3f32, ld: vec3f32, col: vec3f32) vec3f32 =
  let sun = smoothstep(0.21, 0.2, distance(rd, ld)) in
  if sun > 0.0
  then
    let yd  = rd.y - ld.y in
    let a   = sin(3.1 * exp(-yd * 14.0)) in
    let sun2 = sun * smoothstep(-0.8, 0.0, a) in
    mix(col, @[0.75, 0.6, 0.3], sun2)
  else col

------------------------------------------------------------
-- Star-field noise (4 octaves of cellular noise)
------------------------------------------------------------

def starnoise(rd: vec3f32) f32 =
  let p0 = normalize(rd) * 300.0 in
  -- mat3 rotation: [[3/5,0,4/5],[0,1,0],[-4/5,0,3/5]] applied as: p = p*0.6 + 0.5*p*M
  -- Combined: p_new = p*(0.6 + 0.5*M) where M is that mat3
  -- We inline the matrix-vector product directly
  let (_, c_acc) =
    loop (p, c) = (p0, 0.0) for i < 4 do
      let q  = vec.fract(p) - @[0.5, 0.5, 0.5] in
      let id = vec.floor(p) in
      let c2_raw = smoothstep(0.5, 0.0, magnitude(q)) in
      let fi = f32.i32(i) in
      let thresh = 0.06 - fi * fi * 0.005 in
      let h_val  = hash21(@[id.x / id.y, id.z / id.y]) in
      -- step(h, thresh) = 1 if h <= thresh else 0
      let in_star = if h_val <= thresh then 1.0 else 0.0 in
      let c2 = c2_raw * in_star in
      -- Apply rotation: p_new.x = p.x*(0.6 + 0.5*3/5) + p.z*(0.5*4/5)
      --                 p_new.y = p.y*(0.6 + 0.5*1)
      --                 p_new.z = p.x*(0.5*(-4/5)) + p.z*(0.6 + 0.5*3/5)
      let nx = p.x * 0.9 + p.z * 0.4 in
      let ny = p.y * 1.1 in
      let nz = p.x * (-0.4) + p.z * 0.9 in
      (@[nx, ny, nz], c + c2)
  in
  let c1   = c_acc * c_acc in
  -- Galactic-plane modulation
  let g    = dot(@[sin(rd.x * 10.512), sin(rd.y * 10.512), sin(rd.z * 10.512)],
                 @[cos(rd.y * 10.512), cos(rd.z * 10.512), cos(rd.x * 10.512)]) in
  let mod1 = smoothstep(-3.14, -0.9, g) * 0.5 + 0.5 * smoothstep(-0.3, 1.0, g) in
  let c2   = c1 * mod1 in
  c2 * c2

------------------------------------------------------------
-- Sky color
------------------------------------------------------------

def gsky(rd: vec3f32, ld: vec3f32, show_sun: bool) vec3f32 =
  -- Haze = exp2(-5*(|rd.y| - 0.2*dot(rd,ld)))
  let haze_exp = -5.0 * (abs(rd.y) - 0.2 * dot(rd, ld)) in
  let haze     = exp2(haze_exp) in
  -- Stars (only when looking at sky)
  let st   = if show_sun then starnoise(rd) * (1.0 - min(haze, 1.0)) else 0.0 in
  -- Background: purple gradient; textureMirror=0 so no audio modulation
  let back = @[0.4, 0.1, 0.7] in
  let mixed = mix(back, @[0.7, 0.1, 0.4], haze) in
  let col0_r = clamp(mixed.x + st, 0.0, 1.0) in
  let col0_g = clamp(mixed.y + st, 0.0, 1.0) in
  let col0_b = clamp(mixed.z + st, 0.0, 1.0) in
  let col0   = @[col0_r, col0_g, col0_b] in
  if show_sun then addsun(rd, ld, col0) else col0

------------------------------------------------------------
-- Fragment shader
------------------------------------------------------------

#[fragment]
entry fragment_main(#[builtin(position)] fragCoord: vec4f32) #[location(0)] vec4f32 =
  -- Flip Y for Vulkan
  let fc = @[fragCoord.x, iResolution.y - fragCoord.y] in

  -- Camera time (jTime in original; iTimeDelta not available, dt ≈ 0)
  let jt = mod(iTime, 4000.0) in

  -- Screen UV
  let uv = (2.0 * fc - iResolution.xy) / iResolution.y in

  -- Ray origin: scrolling forward at SPEED
  let ro = @[0.0, 1.0, -20000.0 + jt * SPEED] in
  -- Ray direction
  let rd = normalize(@[uv.x, uv.y, 4.0 / 3.0]) in

  -- Intersect terrain
  let (d, edge) = intersect(ro, rd, jt) in

  -- Light direction: slightly animated sun elevation
  let ld = normalize(@[0.0, 0.125 + 0.05 * sin(0.1 * jt), 1.0]) in

  -- Fog (exp2 per-channel, only when terrain was hit)
  let fog = if d > 0.0
            then vec.exp2(d * @[-0.14, -0.1, -0.28])
            else @[0.0, 0.0, 0.0] in

  -- Sky / terrain color
  let sky = gsky(rd, ld, d < 0.0) in
  let p   = @[ro.x + d * rd.x, ro.y + d * rd.y, ro.z + d * rd.z] in
  let n   = normalize(grad3(p, jt)) in
  let diff = dot(n, ld) + 0.1 * n.y in
  let terrain_col = diff * @[0.1, 0.11, 0.18] in
  -- Fresnel-blended reflection
  let rfd    = reflect(rd, n) in
  let rfcol  = gsky(rfd, ld, true) in
  let fres   = 0.05 + 0.95 * (max(1.0 + dot(rd, n), 0.0) ** 5.0) in
  let col0   = mix(terrain_col, rfcol, fres) in
  -- Edge highlight: magenta tint on wireframe edges
  let col1   = mix(col0, @[0.8, 0.1, 0.92], smoothstep(0.05, 0.0, edge)) in
  -- Apply per-channel fog (lerp toward sky)
  let col2   = mix(sky, col1, fog) in

  -- Final: clamp + depth-based alpha
  let alpha = if d < 0.0 then 0.0 else 0.1 + exp2(0.0 - d) in
  @[clamp(col2.x, 0.0, 1.0),
    clamp(col2.y, 0.0, 1.0),
    clamp(col2.z, 0.0, 1.0),
    alpha]

