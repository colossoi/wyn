-- A minimal boids-style particle simulator demonstrating storage-buffer
-- rasterization with self-clearing.
--
-- `sim` (compute) is one entry that:
--   * evolves particle state from `prev_pos` (clumping + alignment
--     forces) and returns the new state via `sim_output` — fed back
--     into `prev_pos` next frame by the host.
--   * self-clears the framebuffer via `map(|_| black, fb)` over a
--     consuming `*[]vec4f32` and `scatter`s one white texel per
--     particle into the cleared buffer at its flattened pixel index.
--   * The returned `new_pos` and the scatter both consume the same
--     SOAC result — the compiler retargets the producer's writes
--     into the entry's output binding and rewrites the scatter's
--     input operand to read through that view
--     (`egir::realize_outputs::dispatch::rewrite_sibling_index_consumers`).
--
-- `main_image` (fragment) samples the framebuffer at the pixel's
-- flat index, so per-pixel cost is O(1) instead of O(particles).
--
-- Exercises `filter(...)` piped into a user-defined size-polymorphic
-- helper (`center` calling `sum`) — the canonical "Abstract array
-- crosses a non-inlined call boundary" pattern that motivates
-- `rep_specialize`.
--
-- Run (cmd.exe; same incantation works in bash with `^` → `\`):
--
--   wyn compile testfiles\playground\particles.wyn ^
--     -o C:\Users\<you>\AppData\Local\Temp\p.spv
--   extra\viz\target\release\viz.exe pipeline ^
--     C:\Users\<you>\AppData\Local\Temp\p.spv ^
--     --feedback sim:prev_pos=sim_output ^
--     --zero-buffer fb:4194304 ^
--     --size 512x512
import "../../lib/noise"

def N:i32 = 512
def CLUMPF:f32 = 0.1
def CLUMPR:f32 = 100.0
def UPDFACTOR:f32 = 1.0
def ALIGNF:f32 = 1.0
def ALIGNR:f32 = 100.0
def RES:i32 = 512

def spawn(i: i32) vec4f32 =
  let k = fasthash.seed(u32.i32(i) * 2654435761u32 + 1u32) in
  @[f32(RES) * fasthash.at_f32(k, 0u32),
    f32(RES) * fasthash.at_f32(k, 1u32),
    2.0 * fasthash.at_f32(k, 2u32) - 1.0,
    2.0 * fasthash.at_f32(k, 3u32) - 1.0]

def sum<[n]>(arr:[n]vec4f32) vec2f32 = reduce(|a,b| a+b, @[0.0,0.0,0.0,0.0], arr).xy
def center(arr:[]vec4f32) vec2f32 = sum(arr)/f32(length(arr))
def clump(pos:vec4f32, arr:[]vec4f32) vec2f32 =
  let filt = filter(|x| magnitude(pos.xy-x.xy)<CLUMPR, arr) in
  let dist = (center(filt) - pos.xy) in
    CLUMPF * dist
def align(pos:vec4f32, arr:[]vec4f32) vec2f32 = ALIGNF*((reduce(|a,b| a+b, @[0.0,0.0], map(|elem| elem.zw, arr)) / f32(N)) - pos.zw)

-- Toroidal wrap of one axis of the particle position: integrate
-- `vel` into `coord` and fold the result into `[0, RES)`.
def wrap(coord: f32, vel: f32) f32 = (coord + UPDFACTOR * vel + f32(RES)) % f32(RES)

-- Flatten `(p.x, p.y)` (a particle position or a fragment coordinate,
-- both `vec4f32`) into a row-major framebuffer index.
def pixel_index(p: vec4f32) i32 = i32.f32(p.y) * RES + i32.f32(p.x)

#[compute]
entry sim(#[storage(set=2, binding=0, access=read)] prev_pos: []vec4f32,
          #[storage(set=2, binding=1, access=write)] fb: *[]vec4f32,
          #[uniform(set=1, binding=1)] iTime: f32) []vec4f32 =
  let new_pos =
    if iTime < 0.1 then
      map(|i:i32| spawn(i), 0i32..<N)
    else
      let prev_pos = prev_pos[0..N] in
      let accelerated =
        map(|elem:vec4f32|
              let deltav = clump(elem, prev_pos) + align(elem, prev_pos) in
              @[elem.x, elem.y, elem.z + deltav.x, elem.w + deltav.y],
            prev_pos)
      in
      map(|upd:vec4f32| @[wrap(upd.x, upd.z), wrap(upd.y, upd.w), upd.z, upd.w],
          accelerated) in
  let cleared = map(|_p:vec4f32| @[0.0, 0.0, 0.0, 1.0], fb) in
  let idxs = map(|p:vec4f32| pixel_index(p), new_pos) in
  let vals = map(|p:vec4f32| @[1.0, 1.0, 1.0, 1.0], new_pos) in
  let _ = scatter(cleared, idxs, vals) in
  new_pos

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vid: i32)
  #[builtin(position)] vec4f32 =
  let x = if vid == 0 then -1.0 else if vid == 1 then 3.0 else -1.0 in
  let y = if vid == 0 then -1.0 else if vid == 1 then -1.0 else 3.0 in
  @[x, y, 0.0, 1.0]

#[fragment]
entry main_image(#[storage(set=2, binding=1, access=read)] fb: []vec4f32,
                 #[builtin(position)] fragCoord: vec4f32)
  #[location(0)] vec4f32 =
  fb[pixel_index(fragCoord)]
