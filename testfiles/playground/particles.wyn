-- A minimal particle simulator demonstrating storage-buffer rasterization.
--
-- `tick` (compute) is the pure simulation: a storage-buffer feedback loop that
-- reads the previous-frame particle state via `prev_pos`, applies a soft
-- clumping + alignment force, and returns the new state.
--
-- `rasterize` (compute) makes a single pass over the particles and `scatter`s
-- one white texel per particle into a 1-D "framebuffer" storage buffer (a
-- flattened RES×RES image: `idx = y*RES + x`). `scatter` consumes the
-- framebuffer once and writes in place — a functional rasterization, no
-- exposed per-element mutation.
--
-- `main_image` (fragment) no longer iterates over particles — it samples the
-- framebuffer at the pixel's flat index, so per-pixel cost is O(1) instead of
-- O(particles).
--
-- Note: the framebuffer is written sparsely (one texel per particle), so the
-- host is expected to clear it each frame; otherwise moving particles leave
-- trails (a known v1 limitation). `scatter` lowers serially in this cut
-- (sequential semantics); a parallel version is a pure-optimization follow-up.
--
-- Exercises `filter(...)` piped into a user-defined size-polymorphic
-- helper (`center` calling `sum`) — the canonical "Abstract array
-- crosses a non-inlined call boundary" pattern that motivates
-- `rep_specialize`.
--
-- Run:
--   wyn compile testfiles/playground/particles.wyn -o /tmp/particles.spv
--   viz pipeline /tmp/particles.spv --feedback tick:prev_pos=tick_output --max-frames 200
import "../../lib/noise"

def N:i32 = 512
def CLUMPF:f32 = 0.1
def CLUMPR:f32 = 100.0
def UPDFACTOR:f32 = 1.0
def ALIGNF:f32 = 1.0
def ALIGNR:f32 = 100.0
def RES:i32 = 512

-- Initial particle state for index `i`, drawn from the integer-hash PCG
-- generator backing lib/noise (`fasthash`). Counter-based randomness is a
-- pure function of (seed, position), so each particle gets an independent,
-- well-distributed draw — no f32-precision collapse like the old
-- `fract(x*y*(x+y))` hash, which piled most particles onto pixel (0,0).
-- Position spans the full [0, RES)² framebuffer; velocity components span
-- [-1, 1).
def spawn(i: i32) vec4f32 =
  let k = fasthash.seed(u32.i32(i) * 2654435761u32 + 1u32) in
  @[f32(RES) * fasthash.at_f32(k, 0u32),
    f32(RES) * fasthash.at_f32(k, 1u32),
    2.0 * fasthash.at_f32(k, 2u32) - 1.0,
    2.0 * fasthash.at_f32(k, 3u32) - 1.0]

def sum<[n]>(arr:[n]vec4f32) vec2f32 = reduce(|a,b| a+b, @[0.0,0.0,0.0,0.0], arr).xy
def center(arr:[]vec4f32) vec2f32 = sum(arr)/f32(length(arr))
def clump(pos:vec4f32, arr:[]vec4f32) vec2f32 =
  let filt = filter(|x| magnitude(pos.xy-x.xy)<CLUMPR, arr) in
  let dist = (center(filt) - pos.xy) in
    CLUMPF * dist
def align(pos:vec4f32, arr:[]vec4f32) vec2f32 = ALIGNF*((reduce(|a,b| a+b, @[0.0,0.0], map(|elem| elem.zw, arr)) / f32(N)) - pos.zw)

#[compute]
entry tick(#[storage(set=2, binding=0, access=read)] prev_pos: []vec4f32,
           #[uniform(set=1, binding=1)] iTime: f32) []vec4f32 =
  if iTime < 0.1 then
    map(|i:i32| spawn(i), 0i32..<N)
  else
    let prev_pos = prev_pos[0..N] in
    map(
      |upd:vec4f32| @[(upd.x + UPDFACTOR * upd.z + 512.0)%512.0,
                     (upd.y + UPDFACTOR * upd.w + 512.0)%512.0,
                     upd.z, upd.w],
      map(|elem:vec4f32|
            let deltav = clump(elem, prev_pos) + align(elem, prev_pos) in
            @[elem.x, elem.y, elem.z + deltav.x, elem.w + deltav.y],
          prev_pos))

-- Single pass over the particles: scatter one white texel per particle into
-- the framebuffer at its flattened pixel index. `fb` is written in place.
#[compute]
entry rasterize(#[storage(set=2, binding=0, access=read)] positions: []vec4f32,
                #[storage(set=2, binding=1, access=write)] fb: []vec4f32) () =
  let pts  = positions[0..N] in
  let idxs = map(|p:vec4f32| i32.f32(p.y) * RES + i32.f32(p.x), pts) in
  let vals = map(|p:vec4f32| @[1.0, 1.0, 1.0, 1.0], pts) in
  let _ = scatter(fb, idxs, vals) in ()

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vid: i32)
  #[builtin(position)] vec4f32 =
  -- Full-screen triangle: three off-screen verts that cover the viewport.
  let x = if vid == 0 then -1.0 else if vid == 1 then 3.0 else -1.0 in
  let y = if vid == 0 then -1.0 else if vid == 1 then -1.0 else 3.0 in
  @[x, y, 0.0, 1.0]

#[fragment]
entry main_image(#[storage(set=2, binding=1, access=read)] fb: []vec4f32,
                 #[builtin(position)] fragCoord: vec4f32)
  #[location(0)] vec4f32 =
  let x = i32.f32(fragCoord.x) in
  let y = i32.f32(fragCoord.y) in
  fb[y * RES + x]
