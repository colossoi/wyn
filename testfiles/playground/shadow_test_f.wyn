-- "Shadow Test F" — Wyn port of a TheArtOfCode-style raymarching demo.
--
-- Two rotating shapes (a torus and a sphere) sitting on a slightly
-- bowled floor, lit by a moving point source, with reflective +
-- refractive treatment of the shapes (IOR 1.5). The camera orbits
-- around the origin while gently bobbing up and down.
--
-- Original GLSL (preserved as a comment block at the bottom) used
-- two undefined helpers from a Shadertoy "Common" tab: `rot(a)` (a
-- 2D rotation matrix) and `thc(a, b)` (a smooth oscillator). They're
-- defined inline below — `thc(a, b) = tanh(a * cos(b))` matches the
-- shape the GLSL uses it for (a [-1, 1]-bounded modulator).
--
-- The original `face()`, `sdBox()`, `hash()`, and `FK` helpers in the
-- GLSL aren't reachable from `mainImage` — dropped here to keep the
-- port tight.

open f32

------------------------------------------------------------
-- Constants
------------------------------------------------------------
def MAX_STEPS: i32 = 400
def MAX_DIST:  f32 = 100.0
def SURF_DIST: f32 = 0.001
def IOR:       f32 = 1.5

------------------------------------------------------------
-- Vertex shader: full-screen triangle
------------------------------------------------------------
def verts: [3]vec4f32 =
  [@[-1.0, -1.0, 0.0, 1.0],
   @[ 3.0, -1.0, 0.0, 1.0],
   @[-1.0,  3.0, 0.0, 1.0]]

#[vertex]
entry vertex_main(#[builtin(vertex_index)] vertex_id: i32) #[builtin(position)] vec4f32 = verts[vertex_id]

------------------------------------------------------------
-- 2D rotation matrix. Right-multiplying a row vector yields a
-- rotation by `+a`, matching GLSL's `p.xz *= rot(a)` convention.
------------------------------------------------------------
def rot(a: f32) mat2f32 =
  let c = cos(a) in
  let s = sin(a) in
  @[[c, s], [-s, c]]

------------------------------------------------------------
-- thc(a, b) — Shadertoy "Common" idiom; tanh-cos modulator.
------------------------------------------------------------
def thc(a: f32, b: f32) f32 =
  tanh(a * cos(b))

------------------------------------------------------------
-- Scene SDF.
--
-- The whole world spins by `rot(0.5*iTime)` first; both shapes (and
-- the ground) live in that frame. The torus additionally counter-
-- rotates locally by `rot(-1.25*iTime)` so it appears to spin
-- independently. The sphere sits one unit to the left of the
-- world's origin, bobbing on `y = 0.25 * sin(iTime)`. The ground is
-- a plane at y = -1 with a shallow upward bowl term.
------------------------------------------------------------
def getDist(p0: vec3f32, iTime: f32) f32 =
  let p_a = p0 with .xz *= rot(0.5 * iTime) in

  -- Torus, centered at +1 on x in the rotated frame, then locally
  -- counter-rotated. The `-1.0` shift on the x component means we
  -- can't use plain `.xz *=` here — we have to spell out the
  -- translated-then-rotated vec2 on the RHS.
  let q = p_a with .xz = (@[p_a.x - 1.0, p_a.z] * rot(-1.25 * iTime)) in
  let r1 = 0.5 in
  let r2 = 0.2 in
  let td1 = magnitude(@[q.x, q.y]) - r1 in
  let sd1 = magnitude(@[td1, q.z]) - r2 in

  -- Sphere center sits at p_a = -(1, 0.25*sin(t), 0).
  let sphereOff = @[1.0, 0.25 * sin(iTime), 0.0] in
  let sd2 = magnitude(p_a + sphereOff) - 0.5 in

  -- Ground plane with a shallow upward bowl: y + 1 - 0.001 * (x² + z²).
  let xz = @[p_a.x, p_a.z] in
  let dGround = p_a.y + 1.0 - 0.001 * dot(xz, xz) in

  min(min(dGround, sd1), sd2)

------------------------------------------------------------
-- Sphere-tracer with sign-flip step refinement: when the sign of
-- `dS` flips relative to the previous step, halve the step length.
-- Lets the original march re-enter the surface after overshooting.
------------------------------------------------------------
def rayMarch(ro: vec3f32, rd: vec3f32, z0: f32, iTime: f32) f32 =
  let s0 = sign(z0) in
  let result = loop (i, dO, z, s) = (0, 0.0, z0, s0) while i < MAX_STEPS do
    let p = ro + rd * dO in
    let dS = getDist(p, iTime) in
    let dSsign = sign(dS) in
    let zs2 = if s != dSsign then (z * 0.5, dSsign) else (z, s) in
    let z2 = zs2.0 in
    let s2 = zs2.1 in
    let stop = abs(dS) < SURF_DIST || dO > MAX_DIST in
    if stop then (MAX_STEPS, dO, z2, s2)
    else (i + 1, dO + dS * z2, z2, s2)
  in
  min(result.1, MAX_DIST)

------------------------------------------------------------
-- Central-difference normal estimation.
------------------------------------------------------------
def getNormal(p: vec3f32, iTime: f32) vec3f32 =
  let d = getDist(p, iTime) in
  let e = 0.001 in
  let nx = d - getDist(p - @[e, 0.0, 0.0], iTime) in
  let ny = d - getDist(p - @[0.0, e, 0.0], iTime) in
  let nz = d - getDist(p - @[0.0, 0.0, e], iTime) in
  normalize(@[nx, ny, nz])

------------------------------------------------------------
-- Camera basis: forward (toward target), right, up; project
-- screen-space (uv) onto the basis at focal length z.
------------------------------------------------------------
def getRayDir(uv: vec2f32, p: vec3f32, l: vec3f32, z: f32) vec3f32 =
  let f = normalize(l - p) in
  let r = normalize(cross(@[0.0, 1.0, 0.0], f)) in
  let u = cross(f, r) in
  let c = f * z in
  let i = c + r * uv.x + u * uv.y in
  normalize(i)

------------------------------------------------------------
-- Fragment shader.
------------------------------------------------------------
#[fragment]
entry fragment_main(#[uniform(set=1, binding=0)] iResolution: vec3f32, #[uniform(set=1, binding=1)] iTime: f32, #[builtin(position)] fragCoord: vec4f32) #[target(screen)] vec4f32 =
  -- Flip Y for Vulkan / WebGPU.
  let fc = @[fragCoord.x, iResolution.y - fragCoord.y] in
  let uv = @[(fc.x - 0.5 * iResolution.x) / iResolution.y,
             (fc.y - 0.5 * iResolution.y) / iResolution.y] in

  -- Orbital camera at radius 4, bobbing gently in y.
  let camR = 4.0 in
  let camA = 0.15 * iTime in
  let ro = @[camR * cos(camA),
             1.0 + 1.0 * cos(0.4 * iTime),
             camR * sin(camA)] in

  let rd = getRayDir(uv, ro, @[0.0, 0.0, 0.0], 1.0) in

  let d = rayMarch(ro, rd, 1.0, iTime) in
  let p = ro + rd * d in

  if d >= MAX_DIST then
    @[0.0, 0.0, 0.0, 1.0]
  else
    let n_raw = getNormal(p, iTime) in

    -- Above y = -0.9 (i.e. on the shapes, not the floor), inflate
    -- the normal before reflecting so highlights look "bumpier" the
    -- closer they are to the origin.
    let pxz = @[p.x, p.z] in
    let pxz_len = magnitude(pxz) in
    let r_norm = if p.y > -0.9 then n_raw * 50.0 * exp(-3.0 * pxz_len) else n_raw in
    let r = reflect(rd, r_norm) in

    -- Inside-march: refract through the surface, march in the
    -- opposite direction (z = -1) until we exit the geometry.
    let pIn  = p - n_raw * (4.0 * SURF_DIST) in
    let rdIn = refract(rd, n_raw, 1.0 / IOR) in
    let dIn  = rayMarch(pIn, rdIn, -1.0, iTime) in
    let pExit = pIn + rdIn * dIn in
    let nExit = -getNormal(pExit, iTime) in

    -- Re-march outward toward the exit point — gives a soft
    -- "look-through" highlight on the back side of the geometry.
    let p2  = p + n_raw * (4.0 * SURF_DIST) in
    let cr  = normalize(p - pExit) in
    let d2  = rayMarch(p2, cr, 1.0, iTime) in
    let p3  = p2 + cr * d2 in
    let n2  = getNormal(p3, iTime) in

    -- Lighting.
    let lightDir1 = normalize(@[0.5 * cos(iTime), 1.0, 0.5 * sin(iTime)]) in
    let dif  = dot(n_raw, lightDir1) * 0.5 + 0.5 in
    let dif2 = dot(n2, normalize(@[1.0, 2.0, 3.0])) * 0.5 + 0.5 in

    let col0 = @[1.0, 1.0, 1.0] * dif in
    let band = 0.5 + 0.5 * thc(4.0, 2.0 * iTime - 0.5 * pxz_len + 50.0 * abs(dif)) in
    let col1 = col0 * band in
    let col2 = col1 * exp(-0.5 * magnitude(p)) in
    let col3 = col2 * (2.0 * dif2) in

    -- Fresnel reflective mix.
    let fres = pow(1.0 + dot(rd, n_raw), 5.0) in
    let csh  = 1.0 / cosh(0.2 * pxz_len) in
    let col_clamped = @[clamp(col3.x, 0.0, 1.0),
                        clamp(col3.y, 0.0, 1.0),
                        clamp(col3.z, 0.0, 1.0)] in
    let r_abs = @[abs(r.x), abs(r.y), abs(r.z)] in
    let col_mixed = mix(col_clamped, r_abs * csh, fres) in

    -- Floor sparkle: an extra log-warped tanh streak under the
    -- shapes, only on the floor (p.y < -0.9).
    let col_final = if p.y < -0.9 then
                      col_mixed + @[0.6, 0.6, 0.6] * thc(4.0, iTime + 6.0 * log(pxz_len)) * csh
                    else col_mixed in

    -- Gamma 2.2 (componentwise pow(col, 0.4545)).
    let g = 0.4545 in
    @[pow(col_final.x, g),
      pow(col_final.y, g),
      pow(col_final.z, g),
      1.0]

