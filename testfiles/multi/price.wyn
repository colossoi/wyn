-- Batch CRR option pricer — compute entry only.
--
-- Owns the GPU-side state (`now`, `rfr` uniforms) and threads it
-- through to the pure pricer in `crr.wyn`.

import "crr"

#[compute]
entry price_options(opts: [](f32, f32, i32, f32, f32),
                    #[uniform(set=1, binding=0)] now: f32,
                    #[uniform(set=1, binding=1)] rfr: f32) []f32 =
  map(|(s, k, t, tte, sigma): (f32, f32, i32, f32, f32)|
        crr_price(now, rfr, s, k, t, tte, sigma),
      opts)
