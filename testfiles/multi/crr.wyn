-- Cox-Ross-Rubinstein binomial-tree American-option pricer.
--
-- Given a list of options, compute each option's fair value via a
-- 32-step CRR tree with early-exercise tested at every node.
--
-- Input row layout (one tuple per option):
--   (spot, strike, opt_type, tte, sigma)
--     spot      current stock price
--     strike    exercise price
--     opt_type  1 = call, 0 (or anything else) = put
--     tte       time to expiration, fractional years from issue date
--     sigma     annualized volatility (0.25 = 25%/yr)
--
-- Uniforms:
--   now   fractional years already elapsed; the effective time-to-expiry
--         used by the tree is max(tte - now, tiny_epsilon).
--   rfr   annualized continuously-compounded risk-free rate (e.g. 0.05).

#[uniform(set=1, binding=0)] def now: f32
#[uniform(set=1, binding=1)] def rfr: f32

-- Tree depth. The node grid carries N+1 values at maturity.
def N: i32 = 32

-- Intrinsic payoff at spot `s` for a call (type=1) or put (any other type).
def payoff(opt_type: i32, s: f32, k: f32) f32 =
  if opt_type == 1 then f32.max(s - k, 0.0) else f32.max(k - s, 0.0)

-- Price one American option via a 32-step CRR tree.
def crr_price(spot0: f32, strike: f32, opt_type: i32, tte: f32, sigma: f32) f32 =
  -- Effective time to expiry, guarded against zero so downstream
  -- `dt = tau / N` is well-defined.
  let tau = f32.max(tte - now, 0.000001) in
  let dt = tau / f32.i32(N) in
  let vol_dt = sigma * f32.sqrt(dt) in      -- σ·√dt
  let u = f32.exp(vol_dt) in                -- up factor
  let d = 1.0 / u in                        -- down factor
  let disc = f32.exp(-rfr * dt) in          -- per-step discount
  let p = (f32.exp(rfr * dt) - d) / (u - d) in  -- risk-neutral up prob
  let invp = 1.0 - p in

  -- Terminal payoff at step N. Node j in 0..=N has
  --   spot(N, j) = spot0 * u^j * d^(N-j) = spot0 * exp(vol_dt * (2j - N))
  -- Slots j > N are unreachable — we size to 33 for convenience and the
  -- backward-induction loop never reads them.
  let terminal: [33]f32 =
    map(|j: i32|
          let exponent = vol_dt * f32.i32(2 * j - N) in
          payoff(opt_type, spot0 * f32.exp(exponent), strike),
        iota(33))
  in

  -- Backward induction from level N-1 down to 0. At level i, slots
  -- j = 0..=i are meaningful; slot > i is zero-filled and not read by
  -- the previous (outer) level. Each level we synthesize a fresh array
  -- via `map` rather than mutating; the compiler can fuse / reuse
  -- buffers as it sees fit.
  let (_, values) =
    loop (i, arr) = (N - 1, terminal) while i >= 0 do
      let arr' = map(|j: i32|
          if j > i then 0.0
          else
            let cont = disc * (p * arr[j + 1] + invp * arr[j]) in
            let exponent = vol_dt * f32.i32(2 * j - i) in
            let intr = payoff(opt_type, spot0 * f32.exp(exponent), strike) in
            f32.max(cont, intr),
        iota(33))
      in (i - 1, arr')
  in values[0]

#[compute]
entry price_options(opts: [](f32, f32, i32, f32, f32)) []f32 =
  map(|(s, k, t, tte, sigma): (f32, f32, i32, f32, f32)|
        crr_price(s, k, t, tte, sigma),
      opts)
